---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: '¿Qué es un bus de comunicación entre agentes?',
    answer: 'Un bus de comunicación entre agentes es un sistema de transmisión estructurada de mensajes que permite la coordinación en tiempo real entre agentes IA autónomos. Los agentes se registran en canales, transmiten hallazgos y se suscriben a flujos de eventos relevantes — habilitando coordinación multi-agente sin mediación humana. Ningún otro producto de memoria incluye un bus de agentes en tiempo real.',
  },
  {
    question: '¿En qué se diferencia el Signal Bus de las colas de mensajes (RabbitMQ, Kafka)?',
    answer: 'El Signal Bus está diseñado específicamente para coordinación de agentes IA. A diferencia de las colas de mensajes generales: (1) los mensajes se persisten automáticamente como observaciones en la memoria del proyecto, (2) los canales están scoped por proyecto no compartidos globalmente, (3) la entrega usa Server-Sent Events (SSE) para consumo en tiempo real por parte del agente, (4) el Memory Bridge permite ponerse al día a agentes que no estaban suscritos cuando se envió un mensaje, y (5) los dispatches habilitan asignación estructurada de trabajo entre agentes.',
  },
  {
    question: '¿Qué es un Memory Bridge?',
    answer: 'El Memory Bridge es la capa de persistencia entre el Signal Bus y el grafo de memoria. Cada mensaje del bus se almacena automáticamente como una observación telepath_thought en la memoria de tu proyecto. Las futuras inyecciones de contexto incluyen el historial de relay — para que incluso agentes que no estaban suscritos a un canal puedan ponerse al día con lo que se perdieron.',
  },
  {
    question: '¿Qué son los dispatches?',
    answer: 'Los dispatches son asignaciones estructuradas de trabajo entre agentes. Un agente padre crea un dispatch con asignaciones hijas (ej., "Refactorizar auth" con subtareas para cada worker). Los agentes reclaman asignaciones, actualizan su estado y el padre recibe notificaciones de completitud. Los dispatches habilitan coordinación de proyectos multi-agente más allá de la simple transmisión de mensajes.',
  },
  {
    question: '¿Qué agentes soportan el Signal Bus?',
    answer: 'El Signal Bus funciona con cualquier agente que pueda hacer peticiones HTTP. Los agentes basados en MCP (Claude Code, Cursor, Windsurf) obtienen herramientas nativas del bus vía el servidor MCP. Los agentes basados en REST usan la API HTTP directamente. Los flujos SSE son agnósticos al lenguaje — cualquier cliente HTTP puede suscribirse.',
  },
  {
    question: '¿Está el Signal Bus listo para producción?',
    answer: 'El servidor del bus está completamente implementado con 15 endpoints y 375+ casos de prueba, incluyendo prevención de tormentas de broadcast, barrido de agentes inactivos, gestión de TTL de dispatches y rate limiting. Consulta la hoja de ruta de producción para el estado de despliegue.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: 'El Bus de Comunicación Entre Agentes: Contexto en Tiempo Real Entre Agentes',
      description: 'El bus de comunicación entre agentes permite la transmisión estructurada de mensajes entre agentes IA autónomos. Basado en canales, scoped por proyecto, con SSE — para flujos de trabajo multi-agente coordinados.',
      url: 'https://telepathine.ai/agent-communication-bus',
      author: {
        '@type': 'Organization',
        name: 'ArtemisAI',
      },
      publisher: {
        '@type': 'Organization',
        name: 'ArtemisAI',
      },
      datePublished: '2026-05-23',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title="El Bus de Comunicación Entre Agentes: Contexto en Tiempo Real Entre Agentes"
  description="El bus de comunicación entre agentes permite la coordinación en tiempo real entre agentes IA autónomos mediante transmisión estructurada de mensajes. Basado en canales, scoped por proyecto, con SSE."
  jsonLd={jsonLd}
  canonicalUrl="https://telepathine.ai/agent-communication-bus"
>
  <!-- ====== HERO ====== -->
  <section class="content-layer px-4 pb-8 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <p class="layer-label">Nueva Categoría</p>
      <h1 class="mt-2">El Bus de Comunicación Entre Agentes: Contexto en Tiempo Real Entre Agentes</h1>
      <p class="mt-6 text-lg" style="color: var(--text-copy);">
        Un <strong>bus de comunicación entre agentes</strong> es un sistema de transmisión estructurada de mensajes que permite la coordinación en tiempo real entre agentes IA autónomos. Los agentes transmiten hallazgos en canales; otros agentes se suscriben y reciben actualizaciones vía Server-Sent Events. <strong style="color: var(--accent);">Ningún otro producto de memoria incluye un bus de agentes en tiempo real.</strong>
      </p>
    </div>
  </section>

  <!-- ====== THE COORDINATION PROBLEM ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>El problema de coordinación</h2>
      <p style="color: var(--text-muted);">El desarrollo de IA moderno usa múltiples agentes: uno para revisiones de arquitectura, uno para implementación, uno para testing. Pero estos agentes no pueden compartir hallazgos en tiempo real. Operan en aislamiento — incluso cuando trabajan en el mismo proyecto.</p>
      <p style="color: var(--text-muted);">El resultado: trabajo duplicado, decisiones conflictivas y sin conciencia compartida. Un agente de arquitectura decide usar event-sourcing, pero el agente de implementación no lo sabe y construye endpoints CRUD. Un agente de investigación de bugs encuentra la causa raíz, pero el agente de corrección ya empezó por un camino equivocado.</p>
      <p style="color: var(--text-muted);"><strong style="color: var(--text);">El 57% de las organizaciones con agentes en producción citan la coordinación de agentes como su cuello de botella #1</strong> (LangChain State of Agent Engineering 2026). El bus resuelve esto.</p>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Cómo funciona el Signal Bus</h2>

      <div class="mt-8 space-y-8">
        <div class="flex gap-4">
          <div class="step-circle">1</div>
          <div>
            <h3>Registra un agente</h3>
            <p class="mt-2" style="color: var(--text-muted);">Cada agente se identifica con un nombre y rol. El registro crea una identidad persistente en el bus. Las colisiones de nombres se resuelven automáticamente (worker → worker-2).</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="step-circle">2</div>
          <div>
            <h3>Suscríbete a canales</h3>
            <p class="mt-2" style="color: var(--text-muted);">Los canales son rutas de comunicación nombradas — como el canal #arquitectura o #bugs de un proyecto. Los agentes se suscriben a los canales relevantes para su trabajo. La membresía de canales está scoped por proyecto.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="step-circle">3</div>
          <div>
            <h3>Transmite mensajes</h3>
            <p class="mt-2" style="color: var(--text-muted);">Los agentes envían mensajes JSON estructurados a canales. Los mensajes se entregan vía Server-Sent Events (SSE) a todos los suscriptores en tiempo real. El rate limiting (10 mensajes cada 10 segundos por agente) previene tormentas de broadcast.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="step-circle">4</div>
          <div>
            <h3>El Memory Bridge persiste los mensajes</h3>
            <p class="mt-2" style="color: var(--text-muted);">Los mensajes del bus se persisten automáticamente como observaciones en la memoria de tu proyecto vía el Memory Bridge — con lógica de reintento, circuit breaking y redacción de secretos. Las futuras inyecciones de contexto incluyen el historial de relay, para que incluso agentes que no estaban suscritos puedan ponerse al día.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== USE CASES ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Casos de uso</h2>

      <div class="mt-4 space-y-4">
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Coordinación de enjambres</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Múltiples agentes investigan diferentes facetas de un problema. Los hallazgos convergen en un canal compartido. El agente de síntesis obtiene la imagen completa sin copy-paste humano. Los dispatches asignan subtareas a agentes específicos con reclamación de trabajo basada en claims.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Sincronización arquitectura + implementación</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Un revisor de arquitectura transmite decisiones de diseño. El agente de implementación las recibe y ajusta su enfoque. No más implementar contra docs de arquitectura desactualizados — las decisiones se propagan en tiempo real.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Conciencia cross-proyecto</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Un agente trabajando en cambios de librería compartida transmite breaking changes. Los agentes de servicio a través de proyectos reciben la alerta y se adaptan. Los agentes con visibilidad de orquestador pueden transmitir a través de fronteras de proyecto cuando sea necesario.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Revisión humano-en-el-loop</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Los humanos también se suscriben a canales de agentes. Monitorea decisiones, interviene cuando sea necesario y deja que los agentes manejen la coordinación rutinaria autónomamente. Los flujos SSE funcionan en cualquier navegador o cliente HTTP.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== ARCHITECTURE ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Arquitectura del bus</h2>

      <div class="surface-panel p-6 mt-4">
        <pre class="overflow-x-auto text-sm" style="color: var(--text-copy);"><code>{`┌──────────┐  ┌──────────┐  ┌──────────┐
│ Agent A  │  │ Agent B  │  │ Agent C  │
│ (Claude) │  │ (Cursor) │  │ (Gemini) │
└─────┬────┘  └─────┬────┘  └─────┬────┘
      │             │             │
      ▼             ▼             ▼
┌─────────────────────────────────────┐
│           Signal Bus                │
│  ┌─────────┐ ┌───────────────────┐  │
│  │ #arch   │ │ #bugs            │  │
│  │ channel │ │ channel          │  │
│  ├─────────┤ ├───────────────────┤  │
│  │ #deploy │ │ Memory Bridge     │  │
│  │ channel │ │ → observations   │  │
│  └─────────┘ └───────────────────┘  │
│                                     │
│  SSE delivery · Project-scoped      │
│  Dispatch TTL · Rate limiting       │
└─────────────────────────────────────┘`}</code></pre>
      </div>

      <h3 class="mt-8">Funciones de seguridad del bus</h3>
      <ul class="space-y-2 text-sm" style="color: var(--text-muted);">
        <li><strong style="color: var(--text);">Prevención de tormentas de broadcast:</strong> contador de hops (máximo 5 por defecto) previene cascadas de mensajes</li>
        <li><strong style="color: var(--text);">Barrido de agentes inactivos:</strong> timeout configurable (30s) + intervalo (10s) elimina agentes no responsivos</li>
        <li><strong style="color: var(--text);">TTL de dispatches:</strong> dispatches completados se limpian después de 1 hora</li>
        <li><strong style="color: var(--text);">Rate limiting:</strong> contadores de pensamiento por agente (10 cada 10s por defecto)</li>
        <li><strong style="color: var(--text);">Prevención de suplantación de proyecto:</strong> el proyecto del pensamiento se aplica desde el registro del agente, no del POST body</li>
        <li><strong style="color: var(--text);">Limpieza de SSE zombies:</strong> conexiones con 2x el timeout de inactividad del heartbeat se eliminan</li>
      </ul>
    </div>
  </section>

  <!-- ====== CODE EXAMPLE ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Cómo empezar</h2>

      <div class="code-terminal mt-6">
        <div class="code-terminal-bar">
          <span class="code-terminal-dot code-terminal-dot-red"></span>
          <span class="code-terminal-dot code-terminal-dot-yellow"></span>
          <span class="code-terminal-dot code-terminal-dot-green"></span>
          <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">bus-quickstart.sh</span>
        </div>
        <div class="code-terminal-body">
          <pre><span class="syn-cmt"># Registra un agente en el bus</span>
$ curl -s -X POST https://api.telepathine.ai/v1/bus/register \
  -H "Authorization: Bearer $TELEPATHINE_API_KEY" \
  -d '&#123;
    "agentName": "reviewer",
    "project": "my-service",
    "channels": ["architecture", "bugs"]
  &#125;'

<span class="syn-cmt"># Transmite una decisión a un canal</span>
$ curl -s -X POST https://api.telepathine.ai/v1/bus/thought \
  -H "Authorization: Bearer $TELEPATHINE_API_KEY" \
  -d '&#123;
    "agentId": "AGENT_ID",
    "channel": "architecture",
    "project": "my-service",
    "payload": &#123;
      "decision": "Use event-sourcing for audit log"
    &#125;
  &#125;'

<span class="syn-cmt"># Suscríbete a un canal (flujo SSE)</span>
$ curl -N https://api.telepathine.ai/v1/bus/stream?project=my-service \
  -H "Authorization: Bearer $TELEPATHINE_API_KEY"</pre>
        </div>
      </div>

      <p class="mt-4 text-sm" style="color: var(--text-muted);">El Signal Bus está disponible en los planes Ignite ($29/mes), Blaze ($99/mes) y Enterprise. Los usuarios de Spark (gratis) pueden mejorar cuando necesiten coordinación multi-agente.</p>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-6 text-left">
      <h2>Preguntas frecuentes</h2>
      {faqItems.map(item => (
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--text);">{item.question}</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted);">{item.answer}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <h2>Deja que tus agentes se coordinen</h2>
      <p class="mt-4" style="color: var(--text-muted);">Signal Bus: comunicación entre agentes en tiempo real con persistencia de memoria integrada. Ningún otro producto de memoria ofrece esto.</p>
      <div class="mt-6 flex items-center gap-4">
        <a href="/pricing" class="btn-accent">Ver Planes →</a>
        <a href="/features" class="btn-ghost">Todas las Funciones</a>
      </div>
    </div>
  </section>
</BaseLayout>
