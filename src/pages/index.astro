---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import LogoWall from '../components/LogoWall.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Telepathine.ai',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  description: 'La capa de memoria portátil para agentes IA. Memoria persistente, búsqueda híbrida, bus de señales en tiempo real. Cualquier motor, cualquier agente.',
  url: 'https://telepathine.ai',
  offers: [
    { '@type': 'Offer', price: '0', priceCurrency: 'USD', name: 'Spark' },
    { '@type': 'Offer', price: '29', priceCurrency: 'USD', name: 'Ignite' },
    { '@type': 'Offer', price: '99', priceCurrency: 'USD', name: 'Blaze' },
  ],
  featureList: ['Signal Bus', 'Persistent Memory', 'Hybrid Search', 'Context Injection', 'Morpheus Pipeline', '17 connectors'],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Por qué se llama Telepathine?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Del griego: tele (distancia) + pathine (sentimiento) — "sentir a distancia." Eso es exactamente lo que la infraestructura permite: agentes IA que comparten entendimiento a través de distancia, sesiones y fronteras de motores.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué es la memoria de agentes IA?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La memoria de agentes IA es una capa de almacenamiento externo persistente que permite a un agente IA retener, recuperar y razonar sobre información a través de sesiones separadas — resolviendo la ausencia de estado fundamental de los modelos de lenguaje grandes. Los sistemas de producción combinan búsqueda por similitud vectorial, búsqueda por palabras clave y grafos de entidades-relaciones, entregando contexto relevante a ~7,000 tokens por consulta vs. 25,000+ para contexto completo — una reducción de costo de tokens del 90% con precisión comparable.',
      },
    },
  ],
};
---

<BaseLayout
  title="Telepathine.ai — La Capa de Memoria Portátil para Agentes IA"
  description="La capa de memoria portátil para agentes IA. Memoria persistente, inyección de contexto multi-modelo, bus de señales en tiempo real. Una API key, 17 conectores, todos los motores."
  jsonLd={jsonLd}
>
  <!-- ====== HERO ====== -->
  <Hero
    title="La capa de memoria portátil para agentes IA"
    subtitle="Una API key. 17 conectores. Todos los motores."
  />

  <!-- ====== PROBLEM STRIP ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-deep);">
    <div class="mx-auto max-w-[1280px] text-left">
      <div class="grid gap-6 md:grid-cols-3">
        <p class="text-lg sm:text-xl" style="color: var(--text); font-family: var(--font-serif); line-height: 1.4;">
          Todo agente IA parte desde cero.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--text); font-family: var(--font-serif); line-height: 1.4;">
          Cada sesión, te vuelves a explicar.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--text-muted); font-family: var(--font-serif); line-height: 1.4;">
          Cada proveedor quiere que siga así.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="content-layer px-4 py-20 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto max-w-[1280px]">
      <span class="layer-label">Pipeline</span>
      <h2 class="mt-4">Cómo funciona</h2>
      <p class="mt-4 max-w-2xl" style="color: var(--text-muted); line-height: 1.7;">
        Cuatro etapas. Entra la salida bruta de herramientas. Sale conocimiento estructurado, buscable e inyectable.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-4">
        <!-- Step 1: Observe -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">1</span>
            <h3 style="margin: 0;">Observar</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Los agentes registran decisiones, cambios, aprendizajes e interacciones con herramientas como observaciones estructuradas. Tipo, título, narrativa, hechos, conceptos — capturados automáticamente.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'agent.observe({ text: "Migrated auth to JWT" })'}</code>
          </div>
        </div>

        <!-- Step 2: Morpheus -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">2</span>
            <h3 style="margin: 0;">Enriquecer</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            El pipeline Morpheus normaliza, deduplica, reemplaza entradas obsoletas, aplica decaimiento temporal, consolida y genera resúmenes de sesión. La salida bruta se convierte en conocimiento estructurado.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'// Automatic on session complete'}</code>
          </div>
        </div>

        <!-- Step 3: Inject -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">3</span>
            <h3 style="margin: 0;">Inyectar</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Revelado progresivo al inicio de sesión: encabezado, línea de tiempo, resumen, pie. ~7,000 tokens de contexto relevante — no 25,000+ de historial bruto. 90% de reducción en costo de tokens.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'await agent.inject({ project: "my-app" })'}</code>
          </div>
        </div>

        <!-- Step 4: Connect -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">4</span>
            <h3 style="margin: 0;">Conectar</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Los agentes transmiten en canales vía el Signal Bus. Coordina enjambres, comparte hallazgos, mantente sincronizado — entre cualquier motor, cualquier modelo, cualquier límite de sesión.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'agent.relay({ channel: "swarm-alpha" })'}</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE 1: SIGNAL BUS ====== -->
  <section class="content-layer px-4 py-24 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto grid max-w-[1280px] items-center gap-16 md:grid-cols-2">
      <div class="flex flex-col gap-6">
        <span class="layer-label">Capa 01</span>
        <h2>Signal Bus</h2>
        <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">
          Relay de alto rendimiento y baja latencia para coordinación de agentes en tiempo real.
          Sincronización directa de estado entre nodos autónomos sin cuellos de botella centralizados.
          Ningún otro producto de memoria incluye un bus de comunicación entre agentes en tiempo real.
        </p>
        <div class="code-snippet">
          <code>{'telepathine.relay({ channel: \'swarm-alpha\' })'}</code>
        </div>
      </div>
      <div class="flex justify-center">
        <div class="w-full max-w-lg rounded-lg border p-8" style="background: var(--bg-card); border-color: var(--line-strong);">
          <svg viewBox="0 0 400 240" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
            <polygon points="200,30 230,47 230,83 200,100 170,83 170,47" stroke="#D4913D" stroke-width="1.5" fill="#D4913D08"/>
            <polygon points="100,100 130,117 130,153 100,170 70,153 70,117" stroke="#D4913D" stroke-width="1.5" fill="#D4913D08"/>
            <polygon points="300,100 330,117 330,153 300,170 270,153 270,117" stroke="#D4913D" stroke-width="1.5" fill="#D4913D08"/>
            <polygon points="150,170 180,187 180,223 150,240 120,223 120,187" stroke="#5A8A5E" stroke-width="1.5" fill="#5A8A5E08"/>
            <polygon points="250,170 280,187 280,223 250,240 220,223 220,187" stroke="#5A8A5E" stroke-width="1.5" fill="#5A8A5E08"/>
            <line x1="200" y1="100" x2="100" y2="100" stroke="#D4913D" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="200" y1="100" x2="300" y2="100" stroke="#D4913D" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="100" y1="170" x2="150" y2="170" stroke="#5A8A5E" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="300" y1="170" x2="250" y2="170" stroke="#5A8A5E" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="150" y1="240" x2="250" y2="240" stroke="#5A8A5E" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.3"/>
            <text x="200" y="70" text-anchor="middle" fill="#D4913D" font-family="monospace" font-size="10">relay</text>
            <text x="100" y="140" text-anchor="middle" fill="#D4913D" font-family="monospace" font-size="10">node-a</text>
            <text x="300" y="140" text-anchor="middle" fill="#D4913D" font-family="monospace" font-size="10">node-b</text>
            <text x="150" y="210" text-anchor="middle" fill="#5A8A5E" font-family="monospace" font-size="10">agent-1</text>
            <text x="250" y="210" text-anchor="middle" fill="#5A8A5E" font-family="monospace" font-size="10">agent-2</text>
            <circle cx="200" cy="65" r="3" fill="#D4913D" opacity="0.8"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE 2: PERSISTENT MEMORY ====== -->
  <section class="content-layer px-4 py-24 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto grid max-w-[1280px] items-center gap-16 md:grid-cols-2">
      <div class="order-2 flex justify-center md:order-1">
        <div class="w-full max-w-lg rounded-lg border p-8" style="background: var(--bg-card); border-color: var(--line-strong);">
          <div class="space-y-4 font-mono text-[10px]" style="color: var(--text-muted); opacity: 0.5;">
            <div class="border-l-2 pl-4 py-2 hover:opacity-80 transition-opacity" style="border-color: var(--accent); opacity: 0.6;">
              <span style="color: var(--accent);">&#123;</span>
              <div class="pl-4">"node_id": <span style="color: var(--accent-secondary);">"mem_0X92"</span>,</div>
              <div class="pl-4">"context": <span style="color: var(--accent-secondary);">"project_theta"</span>,</div>
              <div class="pl-4">"relations": [</div>
              <div class="pl-8">&#123;"type": "causal", "target": "session_88"&#125;,</div>
              <div class="pl-8">&#123;"type": "semantic", "target": "user_intent"&#125;</div>
              <div class="pl-4">]</div>
              <span style="color: var(--accent);">&#125;</span>
            </div>
            <div class="border-l-2 pl-4 py-2" style="border-color: var(--accent); opacity: 0.3;">
              <span style="color: var(--accent);">&#123;</span>
              <div class="pl-4">"node_id": <span style="color: var(--accent-secondary);">"mem_0X93"</span>, ... &#125;</div>
            </div>
          </div>
        </div>
      </div>
      <div class="order-1 flex flex-col gap-6 md:order-2">
        <span class="layer-label">Capa 02</span>
        <h2>Memoria Persistente</h2>
        <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">
          Cada sesión enriquece un grafo de memoria compartido. Los agentes no solo actúan — recuerdan,
          aprenden de despliegues anteriores y construyen sobre estructuras comunes del proyecto.
          Tu memoria debería sobrevivir a tu agente.
        </p>
        <div class="code-snippet">
          <code>{'telepathine.inject({ project: \'my-app\' })'}</code>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE 3: HYBRID SEARCH ====== -->
  <section class="content-layer px-4 py-24 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto grid max-w-[1280px] items-center gap-16 md:grid-cols-2">
      <div class="flex flex-col gap-6">
        <span class="layer-label">Capa 03</span>
        <h2>Búsqueda Híbrida</h2>
        <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">
          Recuperación simultánea por palabras clave y semántica para fundamentar información con precisión.
          FTS + similitud vectorial en una sola consulta, ponderada 60/40 para relevancia óptima.
          Scoped a tu proyecto. Palabra clave o significado — obtén ambos.
        </p>
        <div class="relative max-w-md">
          <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input class="w-full border py-3 pl-10 pr-4 font-mono text-sm" style="background: var(--bg-panel); border-color: var(--line); color: var(--text-copy);" placeholder="Buscar en el grafo de memoria..." type="text" readonly />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="rounded-lg border p-4" style="background: var(--bg-card); border-color: var(--line-strong);">
          <div class="mb-3 h-1 w-8 rounded" style="background: var(--accent); opacity: 0.4;"></div>
          <p class="text-sm" style="color: var(--text);">Semántica: Protocolos de enjambre</p>
          <p class="mt-1 text-xs" style="color: var(--text-muted);">Rank: 0.98 Coincidencia</p>
        </div>
        <div class="rounded-lg border p-4 translate-y-4" style="background: var(--bg-card); border-color: var(--line-strong);">
          <div class="mb-3 h-1 w-8 rounded" style="background: var(--accent-secondary); opacity: 0.4;"></div>
          <p class="text-sm" style="color: var(--text);">Palabra clave: Relay.ts</p>
          <p class="mt-1 text-xs" style="color: var(--text-muted);">Referencia directa de código</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== DIFFERENTIATOR STRIP ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-deep);">
    <div class="mx-auto max-w-[1280px] text-left">
      <div class="grid gap-6 md:grid-cols-3">
        <p class="text-lg sm:text-xl" style="color: var(--text-muted); font-family: var(--font-serif); line-height: 1.4;">
          La memoria de Claude solo funciona con Claude.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--text-muted); font-family: var(--font-serif); line-height: 1.4;">
          La memoria de ChatGPT solo funciona con ChatGPT.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--accent); font-family: var(--font-serif); line-height: 1.4;">
          Telepathine funciona con todos.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== TRUST / PROOF STRIP + LOGO WALL ====== -->
  <section class="content-layer px-4 py-12 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line);">
    <div class="mx-auto max-w-[1280px]">
      <div class="mb-8 flex flex-wrap items-center gap-6">
        <span class="layer-label">17 Connectors</span>
        <span style="color: var(--line);">·</span>
        <span class="layer-label" style="color: var(--accent-secondary);">Aislado con RLS</span>
        <span style="color: var(--line);">·</span>
        <span class="layer-label" style="color: var(--accent-secondary);">BYOK</span>
        <span style="color: var(--line);">·</span>
        <span class="layer-label" style="color: var(--accent-secondary);">Autohospedable</span>
      </div>
      <p class="mb-8 text-left font-mono text-xs uppercase tracking-widest" style="color: var(--text-muted);">Una memoria, cada agente</p>
      <LogoWall />
    </div>
  </section>

  <!-- ====== PRICING ====== -->
  <section class="content-layer py-24 sm:px-6 lg:px-8" style="background: #16131180; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
    <div class="mx-auto max-w-[1280px] px-4">
      <div class="mb-16 text-left">
        <h2>Precios simples, basados en uso</h2>
        <p class="mt-4" style="color: var(--text-muted);">Empieza gratis. Escala cuando estés listo. BYOK en cada plan.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Spark -->
        <div class="pricing-card">
          <div class="flex flex-col gap-2">
            <h3 style="font-family: var(--font-sans);">Spark</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: var(--text);">$0</span>
              <span class="font-mono text-xs" style="color: var(--text-muted);">/month</span>
            </div>
            <p class="font-mono text-xs" style="color: var(--text-muted);">Devs independientes, prototipado</p>
          </div>
          <ul class="flex flex-grow flex-col gap-3">
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 10K observaciones / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 2K inyecciones de contexto / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 5K mensajes de bus / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 1 proyecto
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 5 conectores principales
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 100 resúmenes Morpheus / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> BYOK — tus keys, tus modelos
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Autohospedable (Apache 2.0)
            </li>
          </ul>
          <a href="/pricing" class="block rounded-lg border py-3 text-center font-semibold transition" style="border-color: var(--line-strong); color: var(--text);">Comenzar</a>
        </div>
        <!-- Ignite (featured) -->
        <div class="pricing-card pricing-card-featured relative">
          <span class="pricing-popular-badge">Popular</span>
          <div class="flex flex-col gap-2">
            <h3 style="font-family: var(--font-sans);">Ignite</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: var(--text);">$29</span>
              <span class="font-mono text-xs" style="color: var(--text-muted);">/month</span>
            </div>
            <p class="font-mono text-xs" style="color: var(--text-muted);">Llegando a producción</p>
          </div>
          <ul class="flex flex-grow flex-col gap-3">
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 100K observaciones / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 25K inyecciones de contexto / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 100K mensajes de bus / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 5 proyectos
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Todos los 17 conectores
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 2K resúmenes Morpheus / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Búsqueda híbrida completa
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 99.5% SLA
            </li>
          </ul>
          <a href="/pricing" class="btn-accent block text-center">Empezar con Ignite</a>
        </div>
        <!-- Blaze -->
        <div class="pricing-card">
          <div class="flex flex-col gap-2">
            <h3 style="font-family: var(--font-sans);">Blaze</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: var(--text);">$99</span>
              <span class="font-mono text-xs" style="color: var(--text-muted);">/month</span>
            </div>
            <p class="font-mono text-xs" style="color: var(--text-muted);">Equipos y organizaciones</p>
          </div>
          <ul class="flex flex-grow flex-col gap-3">
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 1M observaciones / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 250K inyecciones de contexto / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 1M mensajes de bus / mes
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Proyectos ilimitados
