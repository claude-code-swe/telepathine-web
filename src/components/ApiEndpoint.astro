---
import type { ApiEndpoint } from '../data/api-endpoints';

export interface Props {
  endpoint: ApiEndpoint;
}

const { endpoint } = Astro.props;

const methodClasses: Record<string, string> = {
  GET: 'method-get',
  POST: 'method-post',
  PUT: 'method-put',
  DELETE: 'method-delete',
};
---

<div class="surface-panel p-5">
  <div class="flex items-center gap-3">
    <span class={`rounded-md px-2 py-0.5 text-xs font-bold ${methodClasses[endpoint.method]}`}>{endpoint.method}</span>
    <code class="text-sm font-mono" style="color: var(--text);">{endpoint.path}</code>
    {endpoint.auth === 'bearer' && (
      <span class="rounded-full border px-2 py-0.5 text-[10px]" style="border-color: var(--line-strong); color: var(--text-muted);">Auth</span>
    )}
  </div>
  <p class="mt-3 text-sm" style="color: var(--text-muted);">{endpoint.description}</p>

  {endpoint.params.length > 0 && (
    <div class="mt-4">
      <p class="mb-2 text-xs font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Parameters</p>
      <table class="w-full text-sm">
        <thead>
          <tr style="border-bottom: 1px solid var(--line);">
            <th class="pb-2 pr-4 text-left text-xs" style="color: var(--text-muted);">Name</th>
            <th class="pb-2 pr-4 text-left text-xs" style="color: var(--text-muted);">In</th>
            <th class="pb-2 pr-4 text-left text-xs" style="color: var(--text-muted);">Type</th>
            <th class="pb-2 pr-4 text-left text-xs" style="color: var(--text-muted);">Required</th>
            <th class="pb-2 text-left text-xs" style="color: var(--text-muted);">Description</th>
          </tr>
        </thead>
        <tbody>
          {endpoint.params.map(p => (
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.7;">
              <td class="py-2 pr-4 font-mono text-xs" style="color: var(--accent);">{p.name}</td>
              <td class="py-2 pr-4 text-xs" style="color: var(--text-muted);">{p.in}</td>
              <td class="py-2 pr-4 text-xs" style="color: var(--text-muted);">{p.type}</td>
              <td class="py-2 pr-4 text-xs">
                {p.required ? <span style="color: var(--color-red);">Required</span> : <span style="color: var(--text-muted); opacity: 0.5;">Optional</span>}
              </td>
              <td class="py-2 text-xs" style="color: var(--text-muted);">{p.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <details class="mt-4">
    <summary class="cursor-pointer text-xs transition" style="color: var(--text-muted);">Response example</summary>
    <pre class="mt-2 overflow-x-auto rounded-lg p-3 text-xs" style="background: var(--bg-code); border: 1px solid var(--line); color: var(--text-copy);"><code>{endpoint.responseExample}</code></pre>
  </details>
</div>
