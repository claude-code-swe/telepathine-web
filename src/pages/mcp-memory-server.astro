---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: '¿Qué es un servidor MCP de memoria?',
    answer: 'Un servidor MCP de memoria expone operaciones de memoria de agentes IA — registrar observaciones, buscar historial, inyectar contexto, gestionar sesiones — como herramientas vía el Model Context Protocol (MCP). Cualquier cliente compatible con MCP (Claude Code, Cursor, Windsurf, etc.) puede conectarse y usar estas herramientas sin escribir peticiones HTTP ni manejar la autenticación de la API.',
  },
  {
    question: '¿En qué se diferencia MCP-nativo de MCP añadido?',
    answer: 'MCP añadido significa envolver una REST API existente en una capa MCP delgada — el agente aún construye peticiones internamente. MCP-nativo significa que el sistema de memoria fue diseñado como herramientas MCP desde el inicio: esquemas de entrada apropiados, parámetros con tipo seguro, autenticación integrada, rate limiting y manejo de errores. El agente llama a una herramienta; el servidor hace todo.',
  },
  {
    question: '¿Qué agentes soportan servidores MCP de memoria?',
    answer: 'Cualquier cliente compatible con MCP. Esto incluye Claude Code, Cursor, Windsurf, Gemini CLI y cualquier agente que implemente el Model Context Protocol. Telepathine también proporciona REST API, SDK de TypeScript y SDK de Python para agentes no-MCP.',
  },
  {
    question: '¿Cuánto tiempo toma la configuración?',
    answer: 'Menos de 30 segundos. Agrega la configuración del servidor MCP a tu .mcp.json o configuración de cliente con tu API key. Tu agente obtiene inmediatamente 13 herramientas de memoria. Sin cambios de código, sin base de datos que configurar.',
  },
  {
    question: '¿Puedo autohospedar el servidor MCP?',
    answer: 'Sí. Todo el stack de Telepathine — REST API, servidor MCP, pipeline Morpheus y Signal Bus — es open source bajo Apache 2.0. Ejecútalo en tu propia infraestructura con tu propia base de datos.',
  },
  {
    question: '¿Cómo ahorra tokens la inyección de contexto?',
    answer: 'La inyección de contexto entrega ~7,000 tokens de contexto relevante por consulta en lugar de 25,000+ para el historial completo de conversación — una reducción de costo de tokens del 90% con precisión comparable (arXiv:2504.19413, ECAI 2025). El servidor MCP llama a inject_context automáticamente al inicio de sesión.',
  },
  {
    question: '¿Qué es el Signal Bus en el servidor MCP?',
    answer: 'El Signal Bus es la capa de comunicación entre agentes en tiempo real. Dos herramientas MCP — broadcast_message y subscribe_channel — permiten a los agentes transmitir mensajes estructurados en canales nombrados y recibirlos vía Server-Sent Events. Los mensajes del bus se persisten automáticamente como observaciones.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: 'Servidor MCP de Memoria — Agrega Memoria Persistente a Cualquier Agente',
      description: 'Agrega memoria persistente a cualquier agente IA compatible con MCP con 13 herramientas — observaciones, búsqueda híbrida, inyección de contexto, ciclo de vida de sesión y comunicación entre agentes. Configuración en 30 segundos.',
      url: 'https://telepathine.ai/mcp-memory-server',
      author: {
        '@type': 'Organization',
        name: 'ArtemisAI',
      },
      publisher: {
        '@type': 'Organization',
        name: 'ArtemisAI',
      },
      datePublished: '2026-05-23',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};

const toolList = [
  { name: 'create_observation', desc: 'Registra una decisión, cambio o aprendizaje', badge: 'post' },
  { name: 'search_observations', desc: 'Búsqueda híbrida (FTS + vector) en la memoria del proyecto', badge: 'get' },
  { name: 'inject_context', desc: 'Inyecta contexto relevante en el prompt del agente (~7K tokens)', badge: 'post' },
  { name: 'start_session', desc: 'Inicia una nueva sesión de agente con contexto de proyecto', badge: 'post' },
  { name: 'complete_session', desc: 'Finaliza sesión y dispara resumen Morpheus', badge: 'post' },
  { name: 'list_sessions', desc: 'Ve el historial de sesiones de un proyecto', badge: 'get' },
  { name: 'get_observation', desc: 'Recupera una observación por ID', badge: 'get' },
  { name: 'update_observation', desc: 'Modifica una observación existente', badge: 'put' },
  { name: 'delete_observation', desc: 'Elimina una observación', badge: 'delete' },
  { name: 'list_projects', desc: 'Ve todos los proyectos con memoria registrada', badge: 'get' },
  { name: 'get_project_stats', desc: 'Conteos de observaciones, actividad de sesiones, tamaño del grafo', badge: 'get' },
  { name: 'search_sessions', desc: 'Busca sesiones por fecha, proyecto o estado', badge: 'get' },
  { name: 'get_session', desc: 'Recupera sesión completa con todas las observaciones', badge: 'get' },
];
---

<BaseLayout
  title="Servidor MCP de Memoria — Agrega Memoria Persistente a Cualquier Agente"
  description="Agrega memoria persistente a cualquier agente IA compatible con MCP. 13 herramientas para observaciones, búsqueda híbrida, inyección de contexto, sesiones y comunicación entre agentes. Configuración en 30 segundos."
  jsonLd={jsonLd}
  canonicalUrl="https://telepathine.ai/mcp-memory-server"
>
  <!-- ====== HERO ====== -->
  <section class="content-layer px-4 pb-8 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <p class="layer-label">Inicio Rápido</p>
      <h1 class="mt-2">Servidor MCP de Memoria — Agrega Memoria Persistente a Cualquier Agente</h1>
      <p class="mt-6 text-lg" style="color: var(--text-copy);">
        Un <strong>servidor MCP de memoria</strong> expone operaciones de memoria persistente — registrar observaciones, buscar historial, inyectar contexto — como herramientas del Model Context Protocol. Cualquier agente compatible con MCP se conecta en 30 segundos. <strong>Reducción de costo de tokens del 90%</strong> con inyección de contexto progresiva (arXiv:2504.19413, ECAI 2025).
      </p>
    </div>
  </section>

  <!-- ====== QUICK START ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Configuración en 30 segundos</h2>
      <div class="code-terminal mt-4">
        <div class="code-terminal-bar">
          <span class="code-terminal-dot code-terminal-dot-red"></span>
          <span class="code-terminal-dot code-terminal-dot-yellow"></span>
          <span class="code-terminal-dot code-terminal-dot-green"></span>
          <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">.mcp.json</span>
        </div>
        <div class="code-terminal-body">
          <pre><span class="syn-cmt">// Agrega a .mcp.json o la configuración de tu cliente:</span>
&#123;
  "mcpServers": &#123;
    "telepathine": &#123;
      "command": "npx",
      "args": ["-y", "@ai-memory/mcp-server"],
      "env": &#123;
        "TELEPATHINE_API_KEY": "your_api_key_here"
      &#125;
    &#125;
  &#125;
&#125;

<span class="syn-cmt">// Eso es todo. Tu agente ahora tiene 13 herramientas de memoria.</span>
<span class="syn-cmt">// Sin cambios de código. Sin base de datos que configurar.</span></pre>
        </div>
      </div>

      <div class="mt-6 flex gap-4">
        <div class="step-circle">1</div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">Instala la configuración</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Agrega la entrada del servidor MCP de arriba a tu <code>.mcp.json</code>, configuración de Claude Code, ajustes de Cursor o cualquier cliente MCP. El comando <code>npx</code> obtiene y ejecuta el servidor automáticamente.</p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="step-circle">2</div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">Configura tu API key</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Reemplaza <code>your_api_key_here</code> con tu API key de Telepathine. Consigue una gratis en telepathine.ai — 10K observaciones/mes, sin tarjeta de crédito.</p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="step-circle">3</div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">Tu agente recuerda</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Inicia una sesión. Registra observaciones. En la próxima sesión, la inyección de contexto entrega ~7,000 tokens de trabajo previo relevante — automáticamente.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== 13 TOOLS ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Las 13 herramientas MCP</h2>
      <p style="color: var(--text-muted);">Cada operación es una herramienta MCP de primera clase con esquemas de entrada apropiados, parámetros con tipo seguro, autenticación integrada, rate limiting y manejo de errores. Tu agente llama a una herramienta — el servidor hace todo.</p>

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        {toolList.map(tool => (
          <div class="surface-card p-3">
            <div class="flex items-center gap-2">
              <code class="text-xs font-mono" style="color: var(--accent);">{tool.name}</code>
              <span class={`tag-mono method-${tool.badge}`}>{tool.badge.toUpperCase()}</span>
            </div>
            <p class="mt-1 text-xs" style="color: var(--text-muted);">{tool.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== WHY MCP-NATIVE ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Por qué MCP-nativo supera a los enfoques acoplados al SDK</h2>
      <p style="color: var(--text-muted);">La mayoría de las soluciones de memoria añaden MCP como un afterthought — un wrapper delgado alrededor de una REST API. El agente aún construye peticiones HTTP, maneja tokens de autenticación, parsea códigos de error. MCP-nativo significa que el sistema de memoria fue diseñado como herramientas desde el inicio:</p>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr style="border-bottom: 1px solid var(--line);">
              <th class="pb-3 pr-4 text-left text-xs" style="color: var(--text-muted);">Dimensión</th>
              <th class="pb-3 px-3 text-left text-xs" style="color: var(--text-muted);">Acoplado al SDK (Mem0)</th>
              <th class="pb-3 pl-3 text-left text-xs" style="color: var(--accent);">MCP-Nativo (Telepathine)</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Integración</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">4 líneas de código SDK por agente</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">1 entrada de config, cero código</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Portabilidad</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Bloqueado al lenguaje del SDK</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">Funciona con cada cliente MCP</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Autenticación</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">El agente gestiona tokens</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">El servidor maneja auth automáticamente</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Manejo de errores</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">El agente debe parsear códigos HTTP</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">Tipos de error MCP, integrados</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Esquema</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Implícito, solo en docs</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">JSON Schema, validado</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Comunicación entre agentes</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">None</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">Signal Bus tools included</td>
            </tr>
            <tr style="opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Autohospedaje</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Docker (parcial)</td>
              <td class="py-3 pl-3" style="color: var(--text-muted);">Apache 2.0, stack completo</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ====== TOKEN SAVINGS ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Ahorro de tokens con inyección de contexto</h2>
      <p style="color: var(--text-muted);">Cada token inyectado en la ventana de contexto de tu agente cuesta dinero. La inyección de contexto con búsqueda híbrida entrega contexto relevante a una fracción del costo del historial completo:</p>

      <div class="mt-6 surface-panel p-6">
        <div class="grid gap-6 sm:grid-cols-3 text-center">
          <div>
            <p class="text-3xl font-bold" style="color: var(--text);">~25K</p>
            <p class="mt-1 text-xs" style="color: var(--text-muted);">Contexto completo (sin memoria)</p>
          </div>
          <div>
            <p class="text-3xl font-bold" style="color: var(--accent);">~7K</p>
            <p class="mt-1 text-xs" style="color: var(--text-muted);">Con inyección de contexto</p>
          </div>
          <div>
            <p class="text-3xl font-bold" style="color: var(--accent-secondary);">~90%</p>
            <p class="mt-1 text-xs" style="color: var(--text-muted);">Reducción de costo de tokens</p>
          </div>
        </div>
        <p class="mt-4 text-center text-xs" style="color: var(--text-muted);">Fuente: arXiv:2504.19413, ECAI 2025 — precisión comparable al 90% menor costo de tokens</p>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-6 text-left">
      <h2>Preguntas frecuentes</h2>
      {faqItems.map(item => (
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--text);">{item.question}</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted);">{item.answer}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <h2>Agrega memoria a tu agente</h2>
      <p class="mt-4" style="color: var(--text-muted);">Una entrada de config. 13 herramientas. Cualquier cliente MCP. Empieza gratis — 10K observaciones/mes, sin tarjeta de crédito.</p>
      <div class="mt-6 flex items-center gap-4">
        <a href="/docs/quickstart" class="btn-accent">Inicio Rápido →</a>
        <a href="/api/mcp" class="btn-ghost">Referencia API MCP</a>
      </div>
    </div>
  </section>
</BaseLayout>
