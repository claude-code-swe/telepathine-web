---
export interface Props {
  title: string;
  subtitle: string;
  code?: string;
}

const { title, subtitle, code } = Astro.props;
---

<section class="content-layer relative overflow-hidden px-4 pb-16 pt-24 sm:px-6 sm:pt-32 lg:px-8">
  <!-- Gradient orbs -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-0 -translate-x-1/2 h-[500px] w-[800px] rounded-full blur-3xl" style="background: var(--accent); opacity: 0.08;"></div>
    <div class="absolute right-0 top-1/3 h-[300px] w-[400px] rounded-full blur-3xl" style="background: var(--accent-secondary); opacity: 0.06;"></div>
  </div>

  <div class="mx-auto max-w-4xl text-center">
    <h1 class="gradient-text">{title}</h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg sm:text-xl" style="font-family: var(--font-serif); font-style: italic; color: var(--text-copy);">{subtitle}</p>
    <div class="mx-auto mt-6 h-0.5 w-16 rounded-full" style="background: linear-gradient(90deg, var(--accent), transparent);"></div>
    <div class="mt-8 flex items-center justify-center gap-4">
      <a href="/pricing" class="btn-accent" style="padding: 0.625rem 1.25rem;">Start Free</a>
      <a href="/docs/quickstart" class="btn-ghost">Quick Start →</a>
    </div>

    <!-- Tabbed install box -->
    <div class="mx-auto mt-12 max-w-xl">
      <div class="install-box">
        <div class="flex items-center justify-between px-4 py-2" style="border-bottom: 1px solid var(--line);">
          <div class="terminal-dots">
            <span class="terminal-dot terminal-dot-red"></span>
            <span class="terminal-dot terminal-dot-yellow"></span>
            <span class="terminal-dot terminal-dot-green"></span>
          </div>
          <div class="install-tabs" id="install-tabs">
            <button class="install-tab is-active" data-tab="npm" onclick="switchInstallTab('npm')">npm</button>
            <button class="install-tab" data-tab="pip" onclick="switchInstallTab('pip')">pip</button>
            <button class="install-tab" data-tab="manual" onclick="switchInstallTab('manual')">curl</button>
          </div>
        </div>
        <div class="install-code" id="install-code-npm"><span class="prefix">$ </span>npx @ai-memory/plugin-claude install</div>
        <div class="install-code" id="install-code-pip" style="display:none;"><span class="prefix">$ </span>pip install agent-memory-hermes</div>
        <div class="install-code" id="install-code-manual" style="display:none;"><span class="prefix">$ </span>curl -s https://telepathine.ai/install.sh | bash</div>
      </div>
    </div>
  </div>
</section>

<script>
  function switchInstallTab(tab: string) {
    document.querySelectorAll('.install-tab').forEach(t => t.classList.remove('is-active'));
    document.querySelector(`.install-tab[data-tab="${tab}"]`)?.classList.add('is-active');
    (document.getElementById('install-code-npm') as HTMLElement).style.display = tab === 'npm' ? '' : 'none';
    (document.getElementById('install-code-pip') as HTMLElement).style.display = tab === 'pip' ? '' : 'none';
    (document.getElementById('install-code-manual') as HTMLElement).style.display = tab === 'manual' ? '' : 'none';
  }
  // Expose globally for onclick handlers
  (window as any).switchInstallTab = switchInstallTab;
</script>
