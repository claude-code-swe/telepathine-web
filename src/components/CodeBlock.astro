---
export interface Props {
  code: string;
  lang?: string;
  title?: string;
}

const { code, lang = 'bash', title } = Astro.props;
---

<div class="surface-panel overflow-hidden">
  <div class="flex items-center justify-between px-4 py-2" style="border-bottom: 1px solid var(--line);">
    <span class="text-xs" style="color: var(--text-muted);">{title || lang}</span>
    <button class="copy-btn text-xs transition" style="color: var(--text-muted);" data-code={code}>Copy</button>
  </div>
  <pre class="overflow-x-auto p-4 text-sm" style="color: var(--text-copy);"><code class="language-{lang}">{code}</code></pre>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = (btn as HTMLElement).dataset.code || '';
      await navigator.clipboard.writeText(code);
      const b = btn as HTMLElement;
      b.textContent = 'Copied!';
      b.style.color = 'var(--accent)';
      setTimeout(() => { b.textContent = 'Copy'; b.style.color = 'var(--text-muted)'; }, 2000);
    });
  });
</script>
