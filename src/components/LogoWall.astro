---
const platforms = [
  'Claude',
  'GPT-4o',
  'Cursor',
  'Windsurf',
  'Aider',
  'Gemini',
  'Llama 3',
  'Mistral',
];
---

<div class="flex flex-wrap items-center gap-x-12 gap-y-8 opacity-50 grayscale transition-all hover:grayscale-0 hover:opacity-80" style="justify-content: flex-start;">
  {platforms.map(name => (
    <span class="font-semibold tracking-tight" style="font-size: 1rem; color: var(--text);">{name}</span>
  ))}
  <span class="text-sm" style="color: var(--text-muted); opacity: 0.5;">+ 9 more</span>
</div>
