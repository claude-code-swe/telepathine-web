---
import '../styles/global.css';
import { BRAND } from '../data/brand';
import { getLocaleFromUrl, localizePath, getAlternateLocale } from '../i18n/utils';
import { t } from '../i18n/ui';
import LangSwitcher from '../components/LangSwitcher';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: object;
  canonicalUrl?: string;
}

const base = import.meta.env.BASE_URL || '/';
const SITE_URL = BRAND.SITE_URL;
const SITE_NAME = BRAND.SITE_NAME;
const DEFAULT_OG_IMAGE = `${base}og-image.svg`;

const { title, description = BRAND.DEFAULT_DESCRIPTION, ogImage = DEFAULT_OG_IMAGE, jsonLd, canonicalUrl } = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const fullTitle = title.includes(' — ') ? title : `${title} — ${SITE_NAME}`;
const resolvedCanonical = canonicalUrl || `${SITE_URL}${Astro.url.pathname.replace(/\/index\.html$/, '').replace(/\.html$/, '')}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${base}${ogImage.replace(/^\//, '')}`;

const alternateLocale = getAlternateLocale(locale);
const currentOgLocale = locale === 'es' ? 'es_ES' : 'en_US';
const alternateOgLocale = alternateLocale === 'es' ? 'es_ES' : 'en_US';

const navLinks = [
  { label: t(locale, 'nav.features'), href: localizePath('/features', locale) },
  { label: t(locale, 'nav.api'), href: localizePath('/api', locale) },
  { label: t(locale, 'nav.docs'), href: localizePath('/docs', locale) },
  { label: t(locale, 'nav.pricing'), href: localizePath('/pricing', locale) },
  { label: t(locale, 'nav.security'), href: localizePath('/security', locale) },
];
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <!-- Base path for client-side scripts -->
    <meta name="base-path" content={base} />
    <!-- Telepathine Logo — Favicon & Icons -->
    <link rel="icon" type="image/svg+xml" href={`${base}icons/favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}icons/favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}icons/favicon-16.png`} />
    <link rel="icon" type="image/x-icon" href={`${base}icons/favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}icons/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}icons/site.webmanifest`} />
    <meta name="theme-color" content="#18120d" />
    <meta name="msapplication-TileColor" content="#18120d" />
    <meta name="msapplication-config" content={`${base}icons/browserconfig.xml`} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={resolvedCanonical} />
    <!-- Hreflang alternate links for multilingual SEO -->
    <link rel="alternate" hreflang="es" href={`${SITE_URL}${localizePath(Astro.url.pathname.replace(/\/index\.html$/, '').replace(/\.html$/, ''), 'es')}`} />
    <link rel="alternate" hreflang="en" href={`${SITE_URL}${localizePath(Astro.url.pathname.replace(/\/index\.html$/, '').replace(/\.html$/, ''), 'en')}`} />
    <link rel="alternate" hreflang="x-default" href={resolvedCanonical} />
    <!-- OG locale -->
    <meta property="og:locale" content={currentOgLocale} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <!-- Geist Sans from Vercel CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/style.min.css" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- IP-based locale detection (first visit only) -->
    <script is:inline>
(function() {
  var KEY = 'telepathine-locale';
  if (localStorage.getItem(KEY)) return;
  var baseMeta = document.querySelector('meta[name="base-path"]');
  var basePrefix = (baseMeta ? baseMeta.getAttribute('content') : '/').replace(/\/+$/, '');
  var path = window.location.pathname;
  if (path.includes('/en/')) {
    localStorage.setItem(KEY, 'en');
    return;
  }
  fetch('https://ipapi.co/json/')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var latamCountries = ['AR','BO','CL','CO','CR','CU','DO','EC','GT','HN','MX','NI','PA','PY','PE','SV','UY','VE','ES','GQ'];
      var isSpanish = latamCountries.indexOf(data.country_code) !== -1;
      var loc = isSpanish ? 'es' : 'en';
      localStorage.setItem(KEY, loc);
      if (loc === 'en') {
        var barePath = path.replace(new RegExp('^' + basePrefix), '') || '/';
        var target = basePrefix + '/en' + barePath;
        window.location.href = target.replace(/\\/+/, '/');
      }
    })
    .catch(function() {
      localStorage.setItem(KEY, 'es');
    });
})();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <!-- ====== STICKY HEADER ====== -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background: #1E1A16cc; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-color: var(--line);">
      <div class="mx-auto flex h-16 max-w-[1280px] items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href={localizePath('/', locale)} class="flex items-center gap-2 font-semibold" style="color: var(--text); font-family: var(--font-sans);">
          <img src={`${base}icons/telepathine-logo-transparent.svg`} alt="Telepathine" width="28" height="28" class="h-7 w-7" />
          {BRAND.SITE_NAME}
        </a>
        <div class="hidden items-center gap-8 md:flex">
          {navLinks.map(link => (
            <a href={link.href} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">{link.label}</a>
          ))}
        </div>
        <div class="flex items-center gap-3">
          <LangSwitcher />
          <a href={localizePath('/pricing', locale)} class="btn-accent" style="padding: 0.5rem 1.25rem; font-size: 0.875rem;">{t(locale, 'hero.startFree')}</a>
          <button id="mobile-menu-btn" class="md:hidden" style="color: var(--text-muted);" aria-label="Toggle menu">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="mobile-menu md:hidden">
        <div class="flex flex-col gap-2 px-4 py-3">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <main class="content-layer pt-16">
      <slot />
    </main>

    <!-- ====== FOOTER ====== -->
    <footer class="content-layer mt-24 border-t py-12" style="background: var(--bg-canvas); border-color: var(--line);">
      <div class="mx-auto flex max-w-[1280px] flex-col items-center justify-between gap-8 px-4 md:flex-row md:items-start md:text-left sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 text-center md:text-left">
          <div class="flex items-center gap-2 font-semibold" style="color: var(--text); font-family: var(--font-sans);">
            <img src={`${base}icons/telepathine-logo-transparent.svg`} alt="Telepathine" width="20" height="20" class="h-5 w-5" />
            {BRAND.SITE_NAME}
          </div>
          <p class="text-sm" style="color: var(--text-muted);">{t(locale, 'footer.copyright')}</p>
        </div>
        <div class="flex flex-wrap justify-center gap-8">
          <a href={localizePath('/features', locale)} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t(locale, 'nav.features')}</a>
          <a href={localizePath('/api', locale)} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t(locale, 'nav.api')}</a>
          <a href={localizePath('/docs', locale)} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t(locale, 'nav.docs')}</a>
          <a href={localizePath('/pricing', locale)} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t(locale, 'nav.pricing')}</a>
          <a href={localizePath('/security', locale)} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t(locale, 'nav.security')}</a>
          <a href="https://github.com/ArtemisAI/agent-memory" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t(locale, 'footer.github')}</a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('is-open'));
    </script>
  </body>
</html>
