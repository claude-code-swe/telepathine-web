---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingTable from '../components/PricingTable.tsx';
import { overagePricing } from '../data/pricing';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AggregateOffer',
  name: 'Planes de Telepathine.ai',
  description: 'Planes de precios para Telepathine.ai — la capa de memoria portátil para agentes IA.',
  lowPrice: '0',
  highPrice: '99',
  priceCurrency: 'USD',
  offerCount: 4,
  offers: [
    { '@type': 'Offer', name: 'Spark', price: '0', priceCurrency: 'USD', description: '10,000 observaciones/mes, 1 proyecto, autohospedable' },
    { '@type': 'Offer', name: 'Ignite', price: '29', priceCurrency: 'USD', description: '100,000 observaciones/mes, 5 proyectos, Signal Bus, BYOK' },
    { '@type': 'Offer', name: 'Blaze', price: '99', priceCurrency: 'USD', description: '1M observaciones/mes, proyectos ilimitados, 10 asientos, SLA 99.9%' },
    { '@type': 'Offer', name: 'Enterprise', price: 'Custom', priceCurrency: 'USD', description: 'Ilimitado, SLA personalizado, on-prem, SSO/SAML' },
  ],
};
---

<BaseLayout
  title="Precios — Telepathine.ai"
  description="Precios simples y transparentes para memoria de agentes IA. Empieza gratis con 10K observaciones. Ignite a $29/mes con todas las funciones. Blaze a $99/mes para enjambres en producción."
  jsonLd={jsonLd}
>
  <!-- ====== HEADER ====== -->
  <section class="content-layer px-4 pb-8 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h1>Precios simples, basados en uso</h1>
      <p class="mt-4 max-w-xl text-lg" style="color: var(--text-muted);">Empieza gratis. Escala cuando estés listo. Sin muros de pago, sin recargos por grafos, sin sorpresas.</p>
    </div>
  </section>

  <!-- ====== PRICING TABLE ====== -->
  <section class="content-layer px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <PricingTable client:load />
    </div>
  </section>

  <!-- ====== CALLOUT: NO GRAPH PAYWALL ====== -->
  <section class="content-layer px-4 py-12 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line);">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-lg border p-6" style="background: var(--bg-card); border-color: var(--accent-outline-soft);">
          <h3 style="font-family: var(--font-sans); font-size: 1rem; font-weight: 600; color: var(--accent);">Sin muro de pago del grafo</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted);">La competencia cobra $249/mes por funciones de grafo de conocimiento. Ignite incluye todo a $29 — memoria, búsqueda, bus, pipeline Morpheus. Sin funciones dentro de funciones.</p>
        </div>
        <div class="rounded-lg border p-6" style="background: var(--bg-card); border-color: var(--accent-secondary-surface-soft, #5A8A5E12);">
          <h3 style="font-family: var(--font-sans); font-size: 1rem; font-weight: 600; color: var(--accent-secondary);">BYOK gratis en todos los planes</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted);">Trae tus propias keys de OpenAI, Anthropic o compatibles en cada plan — incluyendo el plan gratuito. Reduce nuestros costos de infra y genera confianza. Tus keys, tus modelos.</p>
        </div>
        <div class="rounded-lg border p-6" style="background: var(--bg-card); border-color: var(--line-strong);">
          <h3 style="font-family: var(--font-sans); font-size: 1rem; font-weight: 600; color: var(--text);">Autohospedado siempre gratis</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted);">Toda la plataforma es Apache 2.0. Ejecútala en tu propia infraestructura, detrás de tu propio firewall, con tu propia base de datos. Spark es el plan autohospedado — gratis para siempre.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== LAUNCH PROMOTION ====== -->
  <section class="content-layer px-4 py-12 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line-subtle);">
    <div class="mx-auto max-w-5xl">
      <div class="rounded-lg border p-8" style="background: var(--accent-surface-subtle); border-color: var(--accent-outline-soft);">
        <div class="flex items-start gap-4">
          <span class="font-mono text-xs font-semibold uppercase tracking-widest" style="color: var(--accent);">Adoptador Temprano</span>
        </div>
        <h2 class="mt-4" style="font-size: 1.5rem; line-height: 1.3;">50% de descuento en Ignite y Blaze durante los primeros 6 meses</h2>
        <p class="mt-3 text-sm" style="color: var(--text-muted);">Ignite baja a $14.50/mes. Blaze baja a $49.50/mes. Todas las funciones, la mitad del precio. Disponible durante los primeros 6 meses después del lanzamiento.</p>
        <div class="mt-6 grid gap-4 text-sm sm:grid-cols-3" style="color: var(--text-muted);">
          <div>
            <span class="font-semibold" style="color: var(--text);">Programa startup</span><br />
            Blaze gratis por 3 meses. Empresas con menos de $5M de funding.
          </div>
          <div>
            <span class="font-semibold" style="color: var(--text);">Programa académico</span><br />
            Ignite gratis para investigadores verificados.
          </div>
          <div>
            <span class="font-semibold" style="color: var(--text);">Contribuidores OSS</span><br />
            Blaze gratis para los top 50 contribuidores de GitHub.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== OVERAGE PRICING ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line);">
    <div class="mx-auto max-w-5xl">
      <h2>Precios por exceso</h2>
      <p class="mt-4 max-w-xl" style="color: var(--text-muted);">Escala, no penalización. Si excedes los límites de tu plan, pagas una tarifa por unidad — sin limitación, sin interrupción de servicio, sin facturas sorpresa.</p>
      <div class="mt-8 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr style="border-bottom: 1px solid var(--line);">
              <th class="pb-3 pr-4 text-left text-xs" style="color: var(--text-muted);">Métrica</th>
              <th class="pb-3 px-4 text-center text-xs" style="color: var(--text-muted);">Ignite</th>
              <th class="pb-3 pl-4 text-center text-xs" style="color: var(--text-muted);">Blaze</th>
            </tr>
          </thead>
          <tbody>
            {overagePricing.map((row) => (
              <tr style="border-bottom: 1px solid var(--line-subtle);">
                <td class="py-3 pr-4" style="color: var(--text-copy);">{row.metric}</td>
                <td class="py-3 px-4 text-center font-mono" style="color: var(--text-muted);">{row.ignite}</td>
                <td class="py-3 pl-4 text-center font-mono" style="color: var(--text-muted);">{row.blaze}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ====== UPGRADE TRIGGERS ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line-subtle);">
    <div class="mx-auto max-w-5xl">
      <h2>Cuándo mejorar</h2>
      <p class="mt-4 max-w-xl" style="color: var(--text-muted);">Señales naturales, no upsells forzados. Esto es lo que debes observar.</p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="surface-card p-5">
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--accent);">Almacenamiento</span>
          <p class="mt-2 text-sm" style="color: var(--text-copy);">Usaste 8K de 10K observaciones.</p>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Mejora a Ignite para 100K.</p>
        </div>
        <div class="surface-card p-5">
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--accent);">Proyectos</span>
          <p class="mt-2 text-sm" style="color: var(--text-copy);">¿Necesitas un segundo proyecto?</p>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Ignite te da 5. Blaze te da ilimitados.</p>
        </div>
        <div class="surface-card p-5">
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--accent);">Equipo</span>
          <p class="mt-2 text-sm" style="color: var(--text-copy);">¿Agregando un compañero de equipo?</p>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Blaze incluye 10 asientos.</p>
        </div>
        <div class="surface-card p-5">
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--accent);">Cumplimiento</span>
          <p class="mt-2 text-sm" style="color: var(--text-copy);">¿Tu cliente necesita SOC 2?</p>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Blaze incluye registros de auditoría. Enterprise agrega el reporte SOC 2.</p>
        </div>
        <div class="surface-card p-5">
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--accent);">Volumen del bus</span>
          <p class="mt-2 text-sm" style="color: var(--text-copy);">¿Ejecutando enjambres de agentes?</p>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Necesitarás más mensajes de bus. Blaze te da 1M/mes.</p>
        </div>
        <div class="surface-card p-5">
          <span class="font-mono text-xs uppercase tracking-widest" style="color: var(--accent);">Retención</span>
          <p class="mt-2 text-sm" style="color: var(--text-copy);">¿Necesitas memoria más allá de 30 días?</p>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Ignite retiene 1 año. Blaze retiene 2 años.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line);">
    <div class="mx-auto max-w-3xl">
      <h2>FAQ</h2>
      <div class="mt-8 space-y-6">
        <div>
          <h3 class="font-semibold" style="color: var(--text);">¿Qué cuenta como una observación?</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Una observación es cualquier memoria registrada — una decisión, cambio, aprendizaje o interacción con herramienta capturada por tu agente. Tanto observaciones estructuradas como brutas cuentan hacia tu total mensual.</p>
        </div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">¿Puedo traer mis propias keys de IA?</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Sí. En cada plan — incluyendo el plan gratuito — puedes configurar tu propio proveedor de LLM/embeddings: OpenAI, Anthropic o cualquier endpoint compatible. Tus keys están encriptadas en reposo y nunca se comparten entre tenants.</p>
        </div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">¿Qué pasa cuando llego a mi límite?</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">En Ignite y Blaze, el exceso se factura a las tarifas indicadas — sin limitación, sin interrupción de servicio. En Spark, recibirás una respuesta 429 con headers de rate-limit. Tus datos siguen accesibles; solo las escrituras nuevas se pausan hasta el siguiente ciclo.</p>
        </div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">¿Mis datos están aislados de otros tenants?</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">La Seguridad a Nivel de Fila con políticas FORCE asegura que cada consulta esté scoped a tu tenant. Los controles de visibilidad a nivel de proyecto añaden aislamiento adicional. Lo aprendimos por las malas — y publicamos el postmortem en nuestra <a href="/security" class="content-link">página de seguridad</a>.</p>
        </div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">¿Por qué autohospedado solo en Spark?</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Toda la plataforma es Apache 2.0 — siempre puedes autohospedar. Spark es el plan autohospedado (gratis para siempre, ejecútalo tú mismo). Ignite y Blaze son planes cloud gestionados. Enterprise agrega BYOC y opciones on-prem.</p>
        </div>
        <div>
          <h3 class="font-semibold" style="color: var(--text);">¿Pierdo datos si degrad mi plan?</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">No. Tus datos nunca se eliminan por cambios de plan. Si excedes la ventana de retención del plan inferior, las observaciones más antiguas se archivan (siguen exportables, no consultables) hasta que mejoras de nuevo o las exportas.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
