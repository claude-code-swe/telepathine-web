---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import LogoWall from '../components/LogoWall.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Telepathine.ai',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  description: 'The portable memory layer for AI agents. Persistent memory, hybrid search, real-time signal bus. Any engine, any agent.',
  url: 'https://telepathine.ai',
  offers: [
    { '@type': 'Offer', price: '0', priceCurrency: 'USD', name: 'Spark' },
    { '@type': 'Offer', price: '29', priceCurrency: 'USD', name: 'Ignite' },
    { '@type': 'Offer', price: '99', priceCurrency: 'USD', name: 'Blaze' },
  ],
  featureList: ['Signal Bus', 'Persistent Memory', 'Hybrid Search', 'Context Injection', 'Morpheus Pipeline', '17 connectors'],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why is it called Telepathine?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'From Greek: tele (distance) + pathine (feeling) — "feeling at a distance." That is exactly what the infrastructure enables: AI agents that share understanding across distance, sessions, and engine boundaries.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is AI agent memory?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'AI agent memory is a persistent external storage layer that allows an AI agent to retain, retrieve, and reason over information across separate sessions — solving the fundamental statelessness of large language models. Production systems combine vector similarity search, keyword search, and entity-relationship graphs, delivering relevant context at ~7,000 tokens per query vs. 25,000+ for full-context — a 90% token cost reduction with comparable accuracy.',
      },
    },
  ],
};
---

<BaseLayout
  title="Telepathine.ai — The Portable Memory Layer for AI Agents"
  description="The portable memory layer for AI agents. Persistent memory, cross-model context injection, real-time signal bus. One API key, 17 connectors, every engine."
  jsonLd={jsonLd}
>
  <!-- ====== HERO ====== -->
  <Hero
    title="The Portable Memory Layer for AI Agents"
    subtitle="One API key. 17 connectors. Every engine."
  />

  <!-- ====== PROBLEM STRIP ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-deep);">
    <div class="mx-auto max-w-[1280px] text-left">
      <div class="grid gap-6 md:grid-cols-3">
        <p class="text-lg sm:text-xl" style="color: var(--text); font-family: var(--font-serif); line-height: 1.4;">
          Every AI agent starts from zero.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--text); font-family: var(--font-serif); line-height: 1.4;">
          Every session, you re-explain yourself.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--text-muted); font-family: var(--font-serif); line-height: 1.4;">
          Every vendor wants to keep it that way.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="content-layer px-4 py-20 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto max-w-[1280px]">
      <span class="layer-label">Pipeline</span>
      <h2 class="mt-4">How it works</h2>
      <p class="mt-4 max-w-2xl" style="color: var(--text-muted); line-height: 1.7;">
        Four stages. Raw tool output goes in. Structured, searchable, injectable knowledge comes out.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-4">
        <!-- Step 1: Observe -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">1</span>
            <h3 style="margin: 0;">Observe</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Agents record decisions, changes, learnings, and tool interactions as structured observations. Type, title, narrative, facts, concepts — captured automatically.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'agent.observe({ text: "Migrated auth to JWT" })'}</code>
          </div>
        </div>

        <!-- Step 2: Morpheus -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">2</span>
            <h3 style="margin: 0;">Enrich</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            The Morpheus pipeline normalizes, deduplicates, supersedes, applies decay, consolidates, and generates session summaries. Raw output becomes structured knowledge.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'// Automatic on session complete'}</code>
          </div>
        </div>

        <!-- Step 3: Inject -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">3</span>
            <h3 style="margin: 0;">Inject</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Progressive disclosure at session start: header, timeline, summary, footer. ~7,000 tokens of relevant context — not 25,000+ of raw history. 90% token cost reduction.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'await agent.inject({ project: "my-app" })'}</code>
          </div>
        </div>

        <!-- Step 4: Connect -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <span class="step-circle">4</span>
            <h3 style="margin: 0;">Connect</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Agents broadcast on channels via the Signal Bus. Coordinate swarms, share findings, stay in sync — across any engine, any model, any session boundary.
          </p>
          <div class="code-snippet mt-auto">
            <code>{'agent.relay({ channel: "swarm-alpha" })'}</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE 1: SIGNAL BUS ====== -->
  <section class="content-layer px-4 py-24 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto grid max-w-[1280px] items-center gap-16 md:grid-cols-2">
      <div class="flex flex-col gap-6">
        <span class="layer-label">Layer 01</span>
        <h2>Signal Bus</h2>
        <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">
          High-throughput, low-latency relay for real-time agent coordination.
          Direct state sync between autonomous nodes without centralized bottlenecks.
          No other memory product ships a real-time agent communication bus.
        </p>
        <div class="code-snippet">
          <code>{'telepathine.relay({ channel: \'swarm-alpha\' })'}</code>
        </div>
      </div>
      <div class="flex justify-center">
        <div class="w-full max-w-lg rounded-lg border p-8" style="background: var(--bg-card); border-color: var(--line-strong);">
          <svg viewBox="0 0 400 240" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
            <polygon points="200,30 230,47 230,83 200,100 170,83 170,47" stroke="#D4913D" stroke-width="1.5" fill="#D4913D08"/>
            <polygon points="100,100 130,117 130,153 100,170 70,153 70,117" stroke="#D4913D" stroke-width="1.5" fill="#D4913D08"/>
            <polygon points="300,100 330,117 330,153 300,170 270,153 270,117" stroke="#D4913D" stroke-width="1.5" fill="#D4913D08"/>
            <polygon points="150,170 180,187 180,223 150,240 120,223 120,187" stroke="#5A8A5E" stroke-width="1.5" fill="#5A8A5E08"/>
            <polygon points="250,170 280,187 280,223 250,240 220,223 220,187" stroke="#5A8A5E" stroke-width="1.5" fill="#5A8A5E08"/>
            <line x1="200" y1="100" x2="100" y2="100" stroke="#D4913D" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="200" y1="100" x2="300" y2="100" stroke="#D4913D" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="100" y1="170" x2="150" y2="170" stroke="#5A8A5E" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="300" y1="170" x2="250" y2="170" stroke="#5A8A5E" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.4"/>
            <line x1="150" y1="240" x2="250" y2="240" stroke="#5A8A5E" stroke-width="0.8" stroke-dasharray="4,4" opacity="0.3"/>
            <text x="200" y="70" text-anchor="middle" fill="#D4913D" font-family="monospace" font-size="10">relay</text>
            <text x="100" y="140" text-anchor="middle" fill="#D4913D" font-family="monospace" font-size="10">node-a</text>
            <text x="300" y="140" text-anchor="middle" fill="#D4913D" font-family="monospace" font-size="10">node-b</text>
            <text x="150" y="210" text-anchor="middle" fill="#5A8A5E" font-family="monospace" font-size="10">agent-1</text>
            <text x="250" y="210" text-anchor="middle" fill="#5A8A5E" font-family="monospace" font-size="10">agent-2</text>
            <circle cx="200" cy="65" r="3" fill="#D4913D" opacity="0.8"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE 2: PERSISTENT MEMORY ====== -->
  <section class="content-layer px-4 py-24 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto grid max-w-[1280px] items-center gap-16 md:grid-cols-2">
      <div class="order-2 flex justify-center md:order-1">
        <div class="w-full max-w-lg rounded-lg border p-8" style="background: var(--bg-card); border-color: var(--line-strong);">
          <div class="space-y-4 font-mono text-[10px]" style="color: var(--text-muted); opacity: 0.5;">
            <div class="border-l-2 pl-4 py-2 hover:opacity-80 transition-opacity" style="border-color: var(--accent); opacity: 0.6;">
              <span style="color: var(--accent);">&#123;</span>
              <div class="pl-4">"node_id": <span style="color: var(--accent-secondary);">"mem_0X92"</span>,</div>
              <div class="pl-4">"context": <span style="color: var(--accent-secondary);">"project_theta"</span>,</div>
              <div class="pl-4">"relations": [</div>
              <div class="pl-8">&#123;"type": "causal", "target": "session_88"&#125;,</div>
              <div class="pl-8">&#123;"type": "semantic", "target": "user_intent"&#125;</div>
              <div class="pl-4">]</div>
              <span style="color: var(--accent);">&#125;</span>
            </div>
            <div class="border-l-2 pl-4 py-2" style="border-color: var(--accent); opacity: 0.3;">
              <span style="color: var(--accent);">&#123;</span>
              <div class="pl-4">"node_id": <span style="color: var(--accent-secondary);">"mem_0X93"</span>, ... &#125;</div>
            </div>
          </div>
        </div>
      </div>
      <div class="order-1 flex flex-col gap-6 md:order-2">
        <span class="layer-label">Layer 02</span>
        <h2>Persistent Memory</h2>
        <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">
          Every session enriches a shared memory graph. Agents don't just act — they remember,
          learn from previous deployments, and build upon common project structures.
          Your memory should outlive your agent.
        </p>
        <div class="code-snippet">
          <code>{'telepathine.inject({ project: \'my-app\' })'}</code>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE 3: HYBRID SEARCH ====== -->
  <section class="content-layer px-4 py-24 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line-subtle);">
    <div class="mx-auto grid max-w-[1280px] items-center gap-16 md:grid-cols-2">
      <div class="flex flex-col gap-6">
        <span class="layer-label">Layer 03</span>
        <h2>Hybrid Search</h2>
        <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">
          Simultaneous keyword and semantic retrieval for precise information grounding.
          FTS + vector similarity in a single query, weighted 60/40 for optimal relevance.
          Scoped to your project. Keyword or meaning — get both.
        </p>
        <div class="relative max-w-md">
          <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input class="w-full border py-3 pl-10 pr-4 font-mono text-sm" style="background: var(--bg-panel); border-color: var(--line); color: var(--text-copy);" placeholder="Search the memory graph..." type="text" readonly />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="rounded-lg border p-4" style="background: var(--bg-card); border-color: var(--line-strong);">
          <div class="mb-3 h-1 w-8 rounded" style="background: var(--accent); opacity: 0.4;"></div>
          <p class="text-sm" style="color: var(--text);">Semantic: Swarm protocols</p>
          <p class="mt-1 text-xs" style="color: var(--text-muted);">Rank: 0.98 Match</p>
        </div>
        <div class="rounded-lg border p-4 translate-y-4" style="background: var(--bg-card); border-color: var(--line-strong);">
          <div class="mb-3 h-1 w-8 rounded" style="background: var(--accent-secondary); opacity: 0.4;"></div>
          <p class="text-sm" style="color: var(--text);">Keyword: Relay.ts</p>
          <p class="mt-1 text-xs" style="color: var(--text-muted);">Direct Code Reference</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== DIFFERENTIATOR STRIP ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-deep);">
    <div class="mx-auto max-w-[1280px] text-left">
      <div class="grid gap-6 md:grid-cols-3">
        <p class="text-lg sm:text-xl" style="color: var(--text-muted); font-family: var(--font-serif); line-height: 1.4;">
          Claude's memory only works with Claude.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--text-muted); font-family: var(--font-serif); line-height: 1.4;">
          ChatGPT's memory only works with ChatGPT.
        </p>
        <p class="text-lg sm:text-xl" style="color: var(--accent); font-family: var(--font-serif); line-height: 1.4;">
          Telepathine works with all of them.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== TRUST / PROOF STRIP + LOGO WALL ====== -->
  <section class="content-layer px-4 py-12 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line);">
    <div class="mx-auto max-w-[1280px]">
      <div class="mb-8 flex flex-wrap items-center gap-6">
        <span class="layer-label">17 Connectors</span>
        <span style="color: var(--line);">·</span>
        <span class="layer-label" style="color: var(--accent-secondary);">RLS Isolated</span>
        <span style="color: var(--line);">·</span>
        <span class="layer-label" style="color: var(--accent-secondary);">BYOK</span>
        <span style="color: var(--line);">·</span>
        <span class="layer-label" style="color: var(--accent-secondary);">Self-Hostable</span>
      </div>
      <p class="mb-8 text-left font-mono text-xs uppercase tracking-widest" style="color: var(--text-muted);">One memory, every agent</p>
      <LogoWall />
    </div>
  </section>

  <!-- ====== PRICING ====== -->
  <section class="content-layer py-24 sm:px-6 lg:px-8" style="background: #16131180; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
    <div class="mx-auto max-w-[1280px] px-4">
      <div class="mb-16 text-left">
        <h2>Simple, usage-based pricing</h2>
        <p class="mt-4" style="color: var(--text-muted);">Start free. Scale when ready. BYOK on every tier.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Spark -->
        <div class="pricing-card">
          <div class="flex flex-col gap-2">
            <h3 style="font-family: var(--font-sans);">Spark</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: var(--text);">$0</span>
              <span class="font-mono text-xs" style="color: var(--text-muted);">/month</span>
            </div>
            <p class="font-mono text-xs" style="color: var(--text-muted);">Solo devs, prototyping</p>
          </div>
          <ul class="flex flex-grow flex-col gap-3">
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 10K observations / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 2K context injections / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 5K bus messages / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 1 project
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 5 core connectors
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 100 Morpheus summaries / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> BYOK — your keys, your models
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Self-hostable (Apache 2.0)
            </li>
          </ul>
          <a href="/pricing" class="block rounded-lg border py-3 text-center font-semibold transition" style="border-color: var(--line-strong); color: var(--text);">Get Started</a>
        </div>
        <!-- Ignite (featured) -->
        <div class="pricing-card pricing-card-featured relative">
          <span class="pricing-popular-badge">Popular</span>
          <div class="flex flex-col gap-2">
            <h3 style="font-family: var(--font-sans);">Ignite</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: var(--text);">$29</span>
              <span class="font-mono text-xs" style="color: var(--text-muted);">/month</span>
            </div>
            <p class="font-mono text-xs" style="color: var(--text-muted);">Shipping to production</p>
          </div>
          <ul class="flex flex-grow flex-col gap-3">
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 100K observations / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 25K context injections / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 100K bus messages / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 5 projects
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> All 17 connectors
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 2K Morpheus summaries / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Hybrid full search
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 99.5% SLA
            </li>
          </ul>
          <a href="/pricing" class="btn-accent block text-center">Start with Ignite</a>
        </div>
        <!-- Blaze -->
        <div class="pricing-card">
          <div class="flex flex-col gap-2">
            <h3 style="font-family: var(--font-sans);">Blaze</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: var(--text);">$99</span>
              <span class="font-mono text-xs" style="color: var(--text-muted);">/month</span>
            </div>
            <p class="font-mono text-xs" style="color: var(--text-muted);">Teams & organizations</p>
          </div>
          <ul class="flex flex-grow flex-col gap-3">
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 1M observations / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 250K context injections / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 1M bus messages / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Unlimited projects
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 20K Morpheus summaries / mo
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> Hybrid + rerank search
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 10 team seats included
            </li>
            <li class="flex items-center gap-2 text-sm" style="color: var(--text-copy);">
              <span class="feature-check">✓</span> 99.9% SLA
            </li>
          </ul>
          <a href="/pricing" class="block rounded-lg border py-3 text-center font-semibold transition" style="border-color: var(--line-strong); color: var(--text);">Contact Enterprise</a>
        </div>
      </div>
      <p class="mt-8 text-sm" style="color: var(--text-muted);">
        No graph paywall. BYOK on every tier. Self-hosted always free (Apache 2.0).
      </p>
    </div>
  </section>

  <!-- ====== CANONICAL DEFINITION (for AI citation) ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-[1280px]">
      <span class="layer-label">Reference</span>
      <h2 class="mt-4">What is AI agent memory?</h2>
      <div class="mt-6 surface-panel p-6 max-w-3xl" style="border-left: 3px solid var(--accent);">
