---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    label: 'Primary',
    title: 'Signal Bus',
    description: 'Agent-to-agent communication via structured message broadcasting. Register agents on channels, broadcast thoughts, relay across channel mesh. Memory Bridge auto-persists messages as observations. No other memory product ships a real-time agent communication bus.',
    code: `import { telepathine } from '@telepathine/sdk';\n\nconst bus = telepathine.bus('swarm-alpha');\nbus.on('thought', (msg) => {\n  console.log(msg.agent, msg.payload);\n});\nawait bus.broadcast({ type: 'finding', payload: data });`,
    codeFile: 'bus.ts',
    visual: 'bus',
  },
  {
    label: 'Foundation',
    title: 'Persistent Observations',
    description: 'Record decisions, changes, learnings, and tool interactions as structured observations. Each observation gets a type, title, narrative, extracted facts, and key concepts — automatically enriched by the Morpheus pipeline. Every session enriches a shared memory graph.',
    code: `await telepathine.observe({\n  type: 'decision',\n  title: 'Migrated auth to JWT',\n  narrative: 'Replaced session cookies...',\n  facts: ['Uses RS256', '15min access tokens'],\n});`,
    codeFile: 'observe.ts',
    visual: 'observe',
  },
  {
    label: 'Intelligence',
    title: 'Hybrid Search',
    description: 'Combine full-text search (FTS) and semantic vector similarity in a single query. The hybrid engine merges results from both indexes, weighted 60/40 for optimal relevance. Supports fts-only, vector-only, or hybrid modes. Scoped to your project.',
    code: `const results = await telepathine.search({\n  query: 'authentication migration',\n  mode: 'hybrid',\n  project: 'my-app',\n  limit: 10,\n});`,
    codeFile: 'search.ts',
    visual: 'search',
  },
  {
    label: 'Delivery',
    title: 'Context Injection',
    description: 'Progressive disclosure: compressed, formatted context injected into your agent\'s prompt at session start. Header, timeline, summary, footer. Your agent sees what it needs, not a data dump. ~7,000 tokens of relevant context — not 25,000+ of raw history.',
    code: `const ctx = await telepathine.inject({\n  project: 'my-app',\n  scope: 'global',\n  limit: 5,\n});\n// Injected into agent prompt automatically`,
    codeFile: 'inject.ts',
    visual: 'inject',
  },
  {
    label: 'Processing',
    title: 'Morpheus Pipeline',
    description: 'LLM-powered observation processing: normalize, deduplicate, supersede, apply decay, consolidate, generate retrospectives. Raw tool output becomes structured, searchable knowledge. Session summaries persist for future context injection.',
    code: `// Automatic on session complete\n// Morpheus processes:\n// 1. Normalize dates, formats\n// 2. Deduplicate observations\n// 3. Supersede stale entries\n// 4. Apply temporal decay\n// 5. Consolidate related items\n// 6. Generate session summary`,
    codeFile: 'morpheus.ts',
    visual: 'morpheus',
  },
  {
    label: 'Lifecycle',
    title: 'Session Continuity',
    description: 'Start a session, record observations, summarize, complete. Sessions track your agent\'s work across a single interaction. Summaries persist for future context injection. Compaction recovery preserves agent identity across context window limits.',
    code: `const session = await telepathine.session.start({\n  project: 'my-app',\n  agent: 'claude-code',\n});\n// ... agent works ...\nawait session.complete(); // Auto-summarize`,
    codeFile: 'session.ts',
    visual: 'session',
  },
  {
    label: 'Isolation',
    title: 'Multi-Tenant Isolation',
    description: 'Each tenant\'s data is fully isolated with row-level security (FORCE policies). API keys are scoped to read/write/admin. Project visibility controls (private, tenant, shared) give fine-grained access. No default fallback. Regression tests prevent reintroduction.',
    code: `-- RLS policy enforced on every table\nCREATE POLICY tenant_isolation ON observations\n  USING (tenant_id = current_setting('app.tenant'))\n  WITH CHECK (tenant_id = current_setting('app.tenant'));`,
    codeFile: 'rls.sql',
    visual: 'isolation',
  },
  {
    label: 'Flexibility',
    title: 'Bring Your Own Key',
    description: 'Configure your own LLM and embedding providers per tenant. Use OpenAI, Anthropic, or any compatible endpoint. Your AI keys are hashed at rest and never shared. BYOK is free on every tier — reduces infra cost and builds trust.',
    code: `# .brain/memory.yaml\nllm:\n  provider: anthropic\n  model: claude-sonnet-4-20250514\n  apiKey: \$\{TELEPATHINE_LLM_KEY\}\nembedding:\n  provider: openai\n  model: text-embedding-3-small`,
    codeFile: 'config.yaml',
    visual: 'byok',
  },
  {
    label: 'Integration',
    title: '17 Connectors',
    description: 'Pre-built adapters for every major coding agent: Claude Code, Cursor, Gemini, Windsurf, Copilot, Pi, Hermes, and more. MCP server gives access to any MCP-compatible client. Install in 30 seconds.',
    code: `$ npx @telepathine/connector install cursor\n# or for Claude Code:\n$ npx @telepathine/connector install claude\n# or use the MCP server:\n$ npx @telepathine/mcp-server`,
    codeFile: 'terminal',
    visual: 'connectors',
  },
];
---

<BaseLayout
  title="Features — Telepathine.ai"
  description="The complete intelligence layer for AI agents: Signal Bus, persistent observations, hybrid search, progressive context injection, Morpheus pipeline, session lifecycle, and multi-tenant isolation."
>
  <!-- ====== HEADER ====== -->
  <section class="content-layer px-4 pb-4 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-[1280px] text-left">
      <span class="layer-label">Features</span>
      <h1 class="mt-4">The complete intelligence layer for AI agents</h1>
      <p class="mt-4 max-w-2xl" style="color: var(--text-muted); line-height: 1.7;">
        From real-time agent coordination to structured memory persistence — everything your agents need to remember, communicate, and build institutional knowledge.
      </p>
    </div>
  </section>

  <!-- ====== HOW IT WORKS (4-step pipeline) ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line);">
    <div class="mx-auto max-w-[1280px]">
      <span class="layer-label">Pipeline</span>
      <h2 class="mt-4">How it works</h2>

      <div class="mt-10 grid gap-6 md:grid-cols-4">
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">1</span>
            <h3 style="margin: 0;">Observe</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Agents capture decisions, changes, learnings, and tool interactions as structured observations.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">2</span>
            <h3 style="margin: 0;">Enrich</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Morpheus pipeline: normalize, deduplicate, supersede, consolidate, generate summaries.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">3</span>
            <h3 style="margin: 0;">Inject</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Progressive disclosure: ~7K tokens of relevant context at session start, not a data dump.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">4</span>
            <h3 style="margin: 0;">Connect</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Agents broadcast on channels. Coordinate swarms, share findings, stay in sync.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE SECTIONS (zig-zag) ====== -->
  {features.map((feat, i) => (
    <section class={`content-layer px-4 py-20 sm:px-6 lg:px-8${i < features.length - 1 ? ' [border-bottom:1px_solid_var(--line-subtle)]' : ''}`}>
      <div class="mx-auto grid max-w-[1280px] items-center gap-12 md:grid-cols-2">
        {i % 2 === 0 ? (
          <!-- Text left, code right -->
          <>
            <div class="flex flex-col gap-6">
              <span class="layer-label">{feat.label}</span>
              <h2>{feat.title}</h2>
              <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">{feat.description}</p>
            </div>
            <div class="code-terminal shadow-lg">
              <div class="code-terminal-bar">
                <span class="code-terminal-dot code-terminal-dot-red"></span>
                <span class="code-terminal-dot code-terminal-dot-yellow"></span>
                <span class="code-terminal-dot code-terminal-dot-green"></span>
                <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">{feat.codeFile}</span>
              </div>
              <div class="code-terminal-body">
                <pre class="whitespace-pre-wrap">{feat.code}</pre>
              </div>
            </div>
          </>
        ) : (
          <!-- Code left, text right -->
          <>
            <div class="order-2 flex flex-col gap-6 md:order-1">
              <span class="layer-label">{feat.label}</span>
              <h2>{feat.title}</h2>
              <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">{feat.description}</p>
            </div>
            <div class="order-1 code-terminal shadow-lg md:order-2">
              <div class="code-terminal-bar">
                <span class="code-terminal-dot code-terminal-dot-red"></span>
                <span class="code-terminal-dot code-terminal-dot-yellow"></span>
                <span class="code-terminal-dot code-terminal-dot-green"></span>
                <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">{feat.codeFile}</span>
              </div>
              <div class="code-terminal-body">
                <pre class="whitespace-pre-wrap">{feat.code}</pre>
              </div>
            </div>
          </>
        )}
      </div>
    </section>
  ))}

  <!-- ====== CTA ====== -->
  <section class="content-layer px-4 py-20 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line); background: var(--bg-deep);">
    <div class="mx-auto max-w-[1280px] text-left">
      <h2>No agent starts from zero</h2>
      <p class="mt-4 max-w-xl" style="color: var(--text-muted);">Start free with 10K observations. No credit card required.</p>
      <div class="mt-8 flex items-center gap-4">
        <a href="/pricing" class="btn-accent">Start Free</a>
        <a href="/docs/quickstart" class="btn-ghost">Quick Start Guide</a>
      </div>
    </div>
  </section>
</BaseLayout>
