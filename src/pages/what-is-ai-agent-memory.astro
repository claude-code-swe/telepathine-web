---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: 'What is AI agent memory?',
    answer: 'AI agent memory is a persistent external storage layer that allows an AI agent to retain, retrieve, and reason over information across separate sessions — solving the fundamental statelessness of large language models. Production systems combine vector similarity search, keyword search, and entity-relationship graphs to deliver relevant context at ~7,000 tokens per query vs. 25,000+ for full-context — a 90% token cost reduction with comparable accuracy (arXiv:2504.19413, ECAI 2025).',
  },
  {
    question: 'Why do AI agents need memory?',
    answer: 'Large language models are stateless — each session starts with no knowledge of prior interactions. Without external memory, agents forget every decision, convention, and learning between sessions. AI agent memory solves this by capturing observations during work, enriching them into structured knowledge, and injecting relevant context at the start of each new session.',
  },
  {
    question: 'How does AI agent memory reduce token costs?',
    answer: 'Instead of re-injecting entire conversation histories (25,000+ tokens), memory systems retrieve only the most relevant observations using hybrid search — typically ~7,000 tokens per query. This reduces token costs by approximately 90% while maintaining comparable accuracy, as demonstrated in arXiv:2504.19413 (ECAI 2025).',
  },
  {
    question: 'What is the difference between user-scoped and project-scoped memory?',
    answer: 'User-scoped memory ties observations to an individual user account — what one developer learns, another cannot access. Project-scoped memory ties observations to a project, so all agents and developers working on that project share the same knowledge base. Project-scoped memory enables institutional knowledge; user-scoped memory creates silos.',
  },
  {
    question: 'What is a model-agnostic memory layer?',
    answer: 'A model-agnostic memory layer works identically across all LLM providers without vendor-locked storage formats. 70%+ of organizations run 3+ LLM models in production (Datadog 2026). Model-agnostic memory ensures context survives when you switch from Claude to Gemini, or from GPT-4 to a local model.',
  },
  {
    question: 'How does hybrid search work in agent memory?',
    answer: 'Hybrid search combines full-text search (FTS) and semantic vector similarity in a single query. FTS finds exact keyword matches; vector search finds conceptually similar content even without matching terms. Production systems typically weight results 60/40 (FTS/vector) and merge them with a reciprocal rank fusion algorithm for optimal relevance.',
  },
  {
    question: 'What is an agent communication bus?',
    answer: 'An agent communication bus is a structured message broadcasting system that enables real-time coordination between autonomous AI agents. Agents register on channels, broadcast findings, and subscribe to relevant event streams — enabling multi-agent coordination without human mediation. No other memory product ships a real-time agent bus.',
  },
  {
    question: 'Can I self-host AI agent memory?',
    answer: 'Yes — Telepathine.ai is open source under Apache 2.0. You can run the entire memory stack on your own infrastructure: the REST API, MCP server, Morpheus pipeline, and Signal Bus. Self-hosting is free and always will be. Managed cloud is available for teams that prefer not to operate infrastructure.',
  },
  {
    question: 'What is the Morpheus pipeline?',
    answer: 'The Morpheus pipeline is an LLM-powered observation intelligence layer that processes raw agent output into structured, searchable knowledge. It normalizes observations, deduplicates redundant entries, supersedes stale information, applies time-based decay, consolidates related observations, and generates session summaries — all automatically.',
  },
  {
    question: 'How does context injection work?',
    answer: 'Context injection delivers formatted, compressed context to your agent at session start. Instead of dumping raw data, it uses progressive disclosure: header with project metadata, timeline of recent changes, summary of key decisions, and footer with scope information. Your agent receives exactly what it needs — typically ~7,000 tokens instead of 25,000+ for full history.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: 'What Is AI Agent Memory?',
      description: 'AI agent memory is a persistent external storage layer that allows an AI agent to retain, retrieve, and reason over information across separate sessions — solving the fundamental statelessness of large language models.',
      url: 'https://telepathine.ai/what-is-ai-agent-memory',
      author: {
        '@type': 'Organization',
        name: 'ELiA',
      },
      publisher: {
        '@type': 'Organization',
        name: 'ELiA',
      },
      datePublished: '2026-05-23',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title="What Is AI Agent Memory?"
  description="AI agent memory is a persistent external storage layer that allows an AI agent to retain, retrieve, and reason over information across separate sessions — solving the fundamental statelessness of large language models."
  jsonLd={jsonLd}
  canonicalUrl="https://telepathine.ai/what-is-ai-agent-memory"
>
  <!-- ====== HERO ====== -->
  <section class="content-layer px-4 pb-8 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <p class="layer-label">Definitive Guide</p>
      <h1 class="mt-2">What Is AI Agent Memory?</h1>
      <p class="mt-6 text-lg" style="color: var(--text-copy);">
        <strong>AI agent memory</strong> is a persistent external storage layer that allows an AI agent to retain, retrieve, and reason over information across separate sessions — solving the fundamental statelessness of large language models. Production systems combine vector similarity search, keyword search, and entity-relationship graphs, delivering relevant context at ~7,000 tokens per query vs. 25,000+ for full-context — a <strong>90% token cost reduction</strong> with comparable accuracy (arXiv:2504.19413, ECAI 2025).
      </p>
    </div>
  </section>

  <!-- ====== THE PROBLEM ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>The problem: stateless agents</h2>
      <p style="color: var(--text-muted);">Every AI agent starts from zero. When you close a session, the context disappears. Next time you open the same project, you re-explain your architecture, your conventions, your trade-offs. Every. Single. Time.</p>
      <p style="color: var(--text-muted);">This isn't just inconvenient — it's expensive. Re-injecting full conversation histories costs ~25,000+ tokens per query. Repeated explanations waste compute. And your agent can't build on its own prior work because it doesn't remember doing it.</p>
      <p style="color: var(--text-muted);">AI agent memory is the #1 bottleneck cited in <strong style="color: var(--text);">57% of organizations</strong> with agents in production (LangChain State of Agent Engineering 2026). The vector database market supporting these systems hit <strong style="color: var(--text);">$3.2B in 2025</strong>, projected $8.95B by 2030 (27.5% CAGR).</p>

      <div class="surface-panel p-6 mt-6">
        <p class="text-sm font-semibold" style="color: var(--accent);">The lock-in compounding this problem</p>
        <p class="mt-3 text-sm" style="color: var(--text-muted);">Claude's memory only works with Claude. ChatGPT's memory only works with ChatGPT. When you switch agents, your memory doesn't follow — you start from zero again. <strong style="color: var(--text);">70%+ of organizations run 3+ LLM models in production</strong> (Datadog 2026). Vendor-locked memory creates silos across your own toolchain.</p>
      </div>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>How AI agent memory works</h2>
      <p style="color: var(--text-muted);">Production agent memory systems operate as a four-stage pipeline — capture, enrich, inject, and connect:</p>

      <div class="mt-8 space-y-8">
        <div class="flex gap-4">
          <div class="step-circle">1</div>
          <div>
            <h3>Observe — Capture what your agents learn</h3>
            <p class="mt-2" style="color: var(--text-muted);">Record decisions, code changes, learnings, and tool interactions as structured observations. Each observation gets a type, title, narrative, extracted facts, and key concepts. Connectors for Claude Code, Cursor, Gemini, Windsurf, and Copilot capture these automatically via hook pipelines — no manual logging required.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="step-circle">2</div>
          <div>
            <h3>Enrich — The Morpheus pipeline</h3>
            <p class="mt-2" style="color: var(--text-muted);">Raw observations enter the Morpheus pipeline: normalize, deduplicate, supersede stale entries, apply time-based decay, consolidate related observations, and generate session summaries. Raw tool output becomes structured, searchable knowledge — automatically.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="step-circle">3</div>
          <div>
            <h3>Inject — Progressive context delivery</h3>
            <p class="mt-2" style="color: var(--text-muted);">At session start, context injection delivers formatted, compressed context to your agent. Progressive disclosure: header with project metadata → timeline of recent changes → summary of key decisions → footer. Your agent receives ~7,000 tokens of relevant context instead of 25,000+ for full history — a 90% token cost reduction (arXiv:2504.19413, ECAI 2025).</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="step-circle">4</div>
          <div>
            <h3>Connect — The Signal Bus</h3>
            <p class="mt-2" style="color: var(--text-muted);">Agents broadcast findings on channels. Other agents subscribe to those channels and receive updates via Server-Sent Events (SSE) in real time. The Memory Bridge persists bus messages as observations — so even agents that weren't subscribed can catch up later. No other memory product ships a real-time agent communication bus.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TYPES OF MEMORY ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Types of AI agent memory</h2>
      <p style="color: var(--text-muted);">Agent memory systems draw from cognitive science. Three types map to production AI systems:</p>

      <div class="mt-6 space-y-4">
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Episodic memory</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Records specific events: "On May 12, the agent chose event-sourcing for the audit log." Session observations and timelines are episodic. They capture what happened, when, and in what context. Episodic memory is the substrate — without it, agents have no history.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Semantic memory</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Distilled knowledge: "This project uses PostgreSQL with RLS for multi-tenancy." The Morpheus pipeline converts episodic observations into semantic knowledge — extracting facts, concepts, and relationships that survive independent of the original session. Vector embeddings power semantic search over this layer.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Working memory (context injection)</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">The active context window — what your agent sees right now. Context injection populates working memory from episodic and semantic stores. Progressive disclosure delivers only what's relevant: typically ~7,000 tokens vs. 25,000+ for full history, a 90% reduction (arXiv:2504.19413, ECAI 2025).</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== ARCHITECTURE ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Production architecture</h2>
      <p style="color: var(--text-muted);">A production agent memory system combines three retrieval mechanisms:</p>

      <div class="mt-6 space-y-4">
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Vector similarity search</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Embeddings stored in a vector index (pgvector, Pinecone, Weaviate). Enables semantic retrieval: "find observations about authentication" matches even if the word "auth" isn't used. Critical for conceptual queries where exact keywords fail.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Full-text search (FTS)</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">PostgreSQL tsvector-based full-text search with ts_rank scoring. Finds exact keyword matches — essential for code references, API names, and specific identifiers. Production systems weight FTS results ~60% and vector ~40% using reciprocal rank fusion for optimal relevance.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Entity-relationship graph</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Observations linked by causal, semantic, and temporal relationships. Enables traversal queries: "find all decisions that led to the current architecture." The graph layer provides reasoning structure that flat vector search cannot.</p>
        </div>
      </div>

      <div class="mt-8">
        <h3 class="text-sm font-semibold" style="color: var(--text);">Hybrid search in practice</h3>
        <div class="code-terminal mt-4">
          <div class="code-terminal-bar">
            <span class="code-terminal-dot code-terminal-dot-red"></span>
            <span class="code-terminal-dot code-terminal-dot-yellow"></span>
            <span class="code-terminal-dot code-terminal-dot-green"></span>
            <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">hybrid-search.ts</span>
          </div>
          <div class="code-terminal-body">
            <pre><span class="syn-cmt">// Hybrid search: FTS + vector in one query</span>
<span class="syn-kw">const</span> results = <span class="syn-kw">await</span> telepathine.<span class="syn-var">search</span>&#40;&#123;
  query: <span class="syn-str">'authentication architecture decisions'</span>,
  mode:  <span class="syn-str">'hybrid'</span>,     <span class="syn-cmt">// fts-only | vector-only | hybrid</span>
  limit: <span class="syn-str">10</span>,
  project: <span class="syn-str">'my-service'</span>
&#125;&#41;;

<span class="syn-cmt">// Results ranked by reciprocal rank fusion</span>
<span class="syn-cmt">// ~7,000 tokens vs 25,000+ for full context</span>
<span class="syn-cmt">// 90% token cost reduction (arXiv:2504.19413)</span></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== COMPARISON ====== -->
