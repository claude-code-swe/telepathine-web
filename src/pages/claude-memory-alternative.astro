---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: 'Why do I need a Claude memory alternative?',
    answer: 'Claude\'s built-in memory only works within the Claude ecosystem. If you use Cursor for implementation, Gemini for research, or any other agent alongside Claude, your accumulated context stays locked in Claude. A portable alternative ensures your memory travels with your project — not your subscription.',
  },
  {
    question: 'Does Telepathine work with Claude Code?',
    answer: 'Yes — Claude Code is one of our best-supported connectors. Telepathine adds project-scoped memory, hybrid search, the Morpheus pipeline, and the Signal Bus on top of Claude\'s native capabilities. Your Claude sessions write to project memory; other agents read from the same memory.',
  },
  {
    question: 'Can I migrate from Claude memory to Telepathine?',
    answer: 'Yes. Three steps: (1) Install the Telepathine MCP server in your .mcp.json, (2) set your API key, (3) start a session. Existing Claude memory remains in your Claude account — Telepathine adds a portable layer on top. No data loss, no migration friction.',
  },
  {
    question: 'Is project-scoped memory better than user-scoped?',
    answer: 'For teams, yes. User-scoped memory ties observations to one person — what Developer A learns, Developer B cannot access. Project-scoped memory means all agents and developers on a project share the same knowledge base. Institutional knowledge replaces individual silos.',
  },
  {
    question: 'What does the Signal Bus add over Claude memory?',
    answer: 'Claude memory is single-agent — there\'s no way for a Claude session to relay findings to a Cursor session in real time. The Signal Bus enables structured message broadcasting between agents via channels. Findings, decisions, and alerts flow between agents without human mediation.',
  },
  {
    question: 'Can I self-host instead of using Claude\'s cloud?',
    answer: 'Yes. The entire Telepathine stack — REST API, MCP server, Morpheus pipeline, Signal Bus — is open source under Apache 2.0. Run it behind your firewall, on your own database, under your compliance regime.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: 'Claude Memory Alternative — Portable, Project-Scoped Memory',
      description: 'Looking for a Claude memory alternative? Telepathine.ai gives you persistent, project-scoped memory that works with Claude, Cursor, Gemini, and every other agent — not just one.',
      url: 'https://telepathine.ai/claude-memory-alternative',
      author: {
        '@type': 'Organization',
        name: 'ArtemisAI',
      },
      publisher: {
        '@type': 'Organization',
        name: 'ArtemisAI',
      },
      datePublished: '2026-05-23',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title="Claude Memory Alternative — Portable, Project-Scoped"
  description="Claude's memory only works with Claude. Telepathine.ai gives you persistent, project-scoped memory that works with Claude AND every other agent — not just one."
  jsonLd={jsonLd}
  canonicalUrl="https://telepathine.ai/claude-memory-alternative"
>
  <!-- ====== HERO ====== -->
  <section class="content-layer px-4 pb-8 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <p class="layer-label">Alternative</p>
      <h1 class="mt-2">Claude Memory Alternative — Portable, Project-Scoped</h1>
      <p class="mt-6 text-lg" style="color: var(--text-copy);">
        <strong>Claude's memory only works with Claude.</strong> If you use multiple agents or need project-scoped context across a team, you need a portable alternative. Telepathine.ai works with Claude — and every other agent.
      </p>
    </div>
  </section>

  <!-- ====== THE PAIN ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>The vendor lock-in problem</h2>
      <p style="color: var(--text-muted);">Claude's memory is a good start. But every major AI vendor wants to own your memory — because it creates lock-in. The more context you've built up, the harder it is to leave. Your accumulated institutional knowledge becomes a switching cost.</p>

      <div class="mt-6 space-y-4">
        <div class="surface-card p-4" style="border-left: 3px solid var(--accent);">
          <p style="color: var(--text); font-size: 1.125rem; font-weight: 500;">Claude's memory only works with Claude.</p>
        </div>
        <div class="surface-card p-4" style="border-left: 3px solid var(--accent);">
          <p style="color: var(--text); font-size: 1.125rem; font-weight: 500;">ChatGPT's memory only works with ChatGPT.</p>
        </div>
        <div class="surface-card p-4" style="border-left: 3px solid var(--accent-secondary);">
          <p style="color: var(--text); font-size: 1.125rem; font-weight: 500;">Telepathine works with all of them.</p>
        </div>
      </div>

      <p class="mt-4" style="color: var(--text-muted);"><strong style="color: var(--text);">70%+ of organizations run 3+ LLM models in production</strong> (Datadog 2026). When every developer on your team uses a different agent, vendor-locked memory creates silos. Developer A's Claude sessions can't inform Developer B's Cursor sessions.</p>
    </div>
  </section>

  <!-- ====== WHERE CLAUDE FALLS SHORT ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Where Claude memory falls short</h2>

      <div class="mt-4 space-y-4">
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">Vendor lock-in</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Claude memory only works within the Claude ecosystem. Your accumulated context can't travel to Cursor, Gemini, Windsurf, or any other agent. When you switch tools, your memory doesn't follow. Every switch is a reset to zero.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">User-scoped, not project-scoped</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Claude memory is tied to your user account, not your project. When multiple developers work on the same codebase, their memories don't merge into a shared project knowledge base. What one developer teaches Claude, another developer's Claude session never sees.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">No structured intelligence</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Claude memory stores preferences and notes. It doesn't have a Morpheus pipeline — automatic normalization, deduplication, supersession of stale entries, time-based decay, consolidation, and progressive context injection with token budget optimization.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">No agent communication</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Claude memory is single-agent. There's no way for a Claude session to relay findings to a Cursor session in real time. No channel-based communication bus. Agents working on the same project operate in isolation.</p>
        </div>
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--accent);">No self-hosting</h3>
          <p class="mt-1 text-sm" style="color: var(--text-muted);">Claude memory runs on Anthropic's infrastructure. You can't run it behind your firewall, on your own database, or under your compliance regime. No BYOK. No data export API. No Apache 2.0 license.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== COMPARISON TABLE ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Feature comparison</h2>

      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr style="border-bottom: 1px solid var(--line);">
              <th class="pb-3 pr-4 text-left text-xs" style="color: var(--text-muted);">Feature</th>
              <th class="pb-3 px-3 text-left text-xs" style="color: var(--text-muted);">Claude Memory</th>
              <th class="pb-3 pl-3 text-left text-xs" style="color: var(--accent);">Telepathine.ai</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Works with</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Claude only</td>
              <td class="py-3 pl-3" style="color: var(--text);">17 agents (incl. Claude)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Scope</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">User-level</td>
              <td class="py-3 pl-3" style="color: var(--text);">Project-scoped</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Protocol</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Proprietary</td>
              <td class="py-3 pl-3" style="color: var(--text);">MCP-native (13 tools)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Search</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Basic recall</td>
              <td class="py-3 pl-3" style="color: var(--text);">Hybrid (FTS + vector)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Intelligence</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Raw storage</td>
              <td class="py-3 pl-3" style="color: var(--text);">Morpheus pipeline</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Agent comms</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">None</td>
              <td class="py-3 pl-3" style="color: var(--text);">Signal Bus (SSE)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Token cost</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Full context (~25K)</td>
              <td class="py-3 pl-3" style="color: var(--text);">Progressive (~7K)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Self-host</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">No</td>
              <td class="py-3 pl-3" style="color: var(--text);">Apache 2.0</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">BYOK</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">N/A</td>
              <td class="py-3 pl-3" style="color: var(--text);">Every tier</td>
            </tr>
            <tr style="opacity: 0.8;">
              <td class="py-3 pr-4" style="color: var(--text-copy);">Data export</td>
              <td class="py-3 px-3" style="color: var(--text-muted);">Limited</td>
              <td class="py-3 pl-3" style="color: var(--text);">Full REST API</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ====== MIGRATION ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8 text-left">
      <h2>Migrate in 3 steps</h2>
      <p style="color: var(--text-muted);">Telepathine isn't anti-Claude — it's pro-portability. Your Claude sessions continue to work. Telepathine adds a portable memory layer on top.</p>

      <div class="code-terminal mt-6">
        <div class="code-terminal-bar">
          <span class="code-terminal-dot code-terminal-dot-red"></span>
          <span class="code-terminal-dot code-terminal-dot-yellow"></span>
          <span class="code-terminal-dot code-terminal-dot-green"></span>
          <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">migration.sh</span>
        </div>
        <div class="code-terminal-body">
          <pre><span class="syn-cmt">// Step 1: Add Telepathine MCP server to .mcp.json</span>
&#123;
  "mcpServers": &#123;
    "telepathine": &#123;
      "command": "npx",
      "args": ["-y", "@ai-memory/mcp-server"],
      "env": &#123;
        "TELEPATHINE_API_KEY": "your_api_key_here"
      &#125;
    &#125;
  &#125;
&#125;

<span class="syn-cmt">// Step 2: Your Claude Code sessions now write to</span>
<span class="syn-cmt">// project-scoped memory — automatically</span>

<span class="syn-cmt">// Step 3: Other agents read from the same memory</span>
<span class="syn-cmt">// Cursor, Gemini, Windsurf — same project, same context</span>

<span class="syn-cmt">// Existing Claude memory stays in your Claude account.</span>
<span class="syn-cmt">// No data loss. No migration friction.</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8" style="background: #16131180;">
    <div class="mx-auto max-w-3xl space-y-6 text-left">
      <h2>Frequently asked questions</h2>
      {faqItems.map(item => (
        <div class="surface-card p-4">
          <h3 class="text-sm font-semibold" style="color: var(--text);">{item.question}</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted);">{item.answer}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-left">
      <h2>Your memory. Your agents. Your choice.</h2>
      <p class="mt-4" style="color: var(--text-muted);">Start free — 10K observations/month, no credit card. Works with Claude and every other agent.</p>
      <div class="mt-6 flex items-center gap-4">
        <a href="/docs/quickstart" class="btn-accent">Get Started Free →</a>
        <a href="/features" class="btn-ghost">See All Features</a>
      </div>
    </div>
  </section>
</BaseLayout>
