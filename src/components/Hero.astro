---
export interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = 'When agents <em>share memory</em>, they share mind.',
  subtitle = 'The channel layer for AI agents. A unified protocol for persistent memory, cross-model context injection, and real-time coordination.'
} = Astro.props;
---

<section class="content-layer relative px-4 pb-16 pt-28 sm:px-6 sm:pt-36 lg:px-8">
  <div class="mx-auto max-w-[1280px]">
    <div class="grid items-center gap-8 md:grid-cols-12 md:gap-12">
      <!-- Left: 7 cols — messaging -->
      <div class="col-span-7 flex flex-col gap-8 text-left">
        <h1 set:html={title} />
        <p class="max-w-lg text-lg leading-relaxed sm:text-xl" style="color: var(--text-muted); font-family: var(--font-sans);">{subtitle}</p>
        
        <!-- Install command -->
        <div class="max-w-md">
          <div class="install-box flex items-center gap-3">
            <div class="terminal-dots px-3 py-2" style="border-right: 1px solid var(--line);">
              <span class="terminal-dot terminal-dot-red"></span>
              <span class="terminal-dot terminal-dot-yellow"></span>
              <span class="terminal-dot terminal-dot-green"></span>
            </div>
            <code style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--accent);">$ npm i @telepathine/sdk</code>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex items-center gap-4">
          <a href="/pricing" class="btn-accent">Start Free</a>
          <a href="/docs/quickstart" class="btn-ghost">Read Docs →</a>
        </div>
      </div>

      <!-- Right: 5 cols — code terminal -->
      <div class="col-span-5 w-full">
        <div class="code-terminal shadow-2xl">
          <div class="code-terminal-bar">
            <span class="code-terminal-dot code-terminal-dot-red"></span>
            <span class="code-terminal-dot code-terminal-dot-yellow"></span>
            <span class="code-terminal-dot code-terminal-dot-green"></span>
            <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">agent.ts</span>
          </div>
          <div class="code-terminal-body min-h-[300px]">
            <pre><span class="syn-kw">import</span> <span class="syn-var">&#123; telepathine &#125;</span> <span class="syn-kw">from</span> <span class="syn-str">'@telepathine/sdk'</span>;

<span class="syn-kw">const</span> <span class="syn-var">agent</span> = telepathine.init();

<span class="syn-kw">await</span> agent.<span class="syn-var">inject</span>(&#123;
  memory: <span class="syn-str">'shared-context-v4'</span>,
  scope:  <span class="syn-str">'global'</span>
&#125;);

<span class="syn-cmt">// Channel established.</span></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  h1 {
    font-family: var(--font-serif);
    font-weight: 400;
   	line-height: 1.05;
  }
  h1 em {
    font-style: italic;
    color: var(--accent);
  }
</style>
