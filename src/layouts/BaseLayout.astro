---
import '../styles/global.css';
import { BRAND } from '../data/brand';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: object;
  canonicalUrl?: string;
}

const SITE_URL = BRAND.SITE_URL;
const SITE_NAME = BRAND.SITE_NAME;
const DEFAULT_OG_IMAGE = '/og-image.svg';

const { title, description = BRAND.DEFAULT_DESCRIPTION, ogImage = DEFAULT_OG_IMAGE, jsonLd, canonicalUrl } = Astro.props;

const fullTitle = title.includes(' — ') ? title : `${title} — ${SITE_NAME}`;
const resolvedCanonical = canonicalUrl || `${SITE_URL}${Astro.url.pathname.replace(/\/index\.html$/, '').replace(/\.html$/, '')}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;

const navLinks = [
  { label: 'Features', href: '/features' },
  { label: 'API', href: '/api' },
  { label: 'Docs', href: '/docs' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Security', href: '/security' },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen antialiased">
    <!-- ====== STICKY HEADER ====== -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background: #1E1A16cc; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-color: var(--line);">
      <div class="mx-auto flex h-16 max-w-[1280px] items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-2 font-semibold" style="color: var(--text); font-family: var(--font-sans);">
          <!-- Hex logo mark -->
          <span class="flex h-8 w-8 items-center justify-center border" style="border-color: var(--accent); color: var(--accent);">
            <svg width="16" height="16" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 4L58 18V46L32 60L6 46V18L32 4Z" stroke="currentColor" stroke-width="3" fill="none"/>
              <path d="M32 22L40 26.5V35.5L32 40L24 35.5V26.5L32 22Z" fill="currentColor"/>
            </svg>
          </span>
          Telepathine.ai
        </a>
        <div class="hidden items-center gap-8 md:flex">
          {navLinks.map(link => (
            <a href={link.href} class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">{link.label}</a>
          ))}
        </div>
        <div class="flex items-center gap-3">
          <a href="/pricing" class="btn-accent" style="padding: 0.5rem 1.25rem; font-size: 0.875rem;">Start Free</a>
          <button id="mobile-menu-btn" class="md:hidden" style="color: var(--text-muted);" aria-label="Toggle menu">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="mobile-menu md:hidden">
        <div class="flex flex-col gap-2 px-4 py-3">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <main class="content-layer pt-16">
      <slot />
    </main>

    <!-- ====== FOOTER ====== -->
    <footer class="content-layer mt-24 border-t py-12" style="background: var(--bg-canvas); border-color: var(--line);">
      <div class="mx-auto flex max-w-[1280px] flex-col items-center justify-between gap-8 px-4 md:flex-row md:items-start md:text-left sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 text-center md:text-left">
          <div class="font-semibold" style="color: var(--text); font-family: var(--font-sans);">Telepathine.ai</div>
          <p class="text-sm" style="color: var(--text-muted);">© 2026 ArtemisAI. All rights reserved.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-8">
          <a href="/features" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Features</a>
          <a href="/api" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">API</a>
          <a href="/docs" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Docs</a>
          <a href="/pricing" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Pricing</a>
          <a href="/security" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Security</a>
          <a href="https://github.com/ArtemisAI/agent-memory" class="transition" style="color: var(--text-muted); font-size: 0.875rem;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('is-open'));
    </script>
  </body>
</html>
