---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'MCP Memory Server — Model Context Protocol Memory',
  description: 'MCP memory server gives AI agents persistent memory via the Model Context Protocol. 16 tools, project-scoped, hybrid search, context injection — for any MCP-compatible client.',
  url: 'https://telepathine.ai/mcp-memory-server',
  author: {
    '@type': 'Organization',
    name: 'ArtemisAI',
  },
};

const toolList = [
  { name: 'create_observation', desc: 'Record a decision, change, or learning' },
  { name: 'search_observations', desc: 'Hybrid search across project memory' },
  { name: 'inject_context', desc: 'Inject relevant context into the agent prompt' },
  { name: 'start_session', desc: 'Begin a new agent session' },
  { name: 'complete_session', desc: 'End session and trigger summarization' },
  { name: 'list_sessions', desc: 'View session history for a project' },
  { name: 'get_observation', desc: 'Retrieve a single observation by ID' },
  { name: 'update_observation', desc: 'Modify an existing observation' },
  { name: 'delete_observation', desc: 'Remove an observation' },
  { name: 'list_projects', desc: 'See all projects with recorded memory' },
  { name: 'get_project_stats', desc: 'Observation counts, session activity' },
  { name: 'search_sessions', desc: 'Find sessions by date, project, or status' },
  { name: 'get_session', desc: 'Retrieve full session with observations' },
  { name: 'broadcast_message', desc: 'Send a message on the Signal Bus' },
  { name: 'list_channels', desc: 'View active communication channels' },
  { name: 'subscribe_channel', desc: 'Subscribe an agent to a channel' },
];
---

<BaseLayout
  title="MCP Memory Server"
  description="MCP memory server for AI agents. 16 tools via the Model Context Protocol — persistent observations, hybrid search, context injection, session lifecycle, and agent communication."
  jsonLd={jsonLd}
  canonicalUrl="https://telepathine.ai/mcp-memory-server"
>
  <section class="content-layer px-4 pb-8 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="text-sm uppercase tracking-widest" style="color: var(--text-muted);">Guide</p>
      <h1 class="mt-2">MCP Memory Server</h1>
      <p class="mt-6 text-lg" style="color: var(--text-muted);">Give any MCP-compatible AI agent persistent memory with 16 tools — observations, search, context injection, sessions, and agent communication.</p>
    </div>
  </section>

  <section class="content-layer section-divider px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-8">
      <div>
        <h2>What is an MCP memory server?</h2>
        <p class="mt-3" style="color: var(--text-muted);">The Model Context Protocol (MCP) is an open standard for connecting AI models to external tools and data sources. An MCP memory server exposes memory operations — recording observations, searching history, injecting context — as MCP tools that any compatible client can call.</p>
        <p class="mt-3" style="color: var(--text-muted);">Telepathine.ai ships a production MCP server with 16 tools. It works with Claude Code, Cursor, Windsurf, and any MCP-compatible client out of the box.</p>
      </div>

      <div>
        <h2>Setup in 30 seconds</h2>
        <pre class="mt-4 overflow-x-auto rounded-lg p-4 text-sm" style="background: var(--bg-code); border: 1px solid var(--line); color: var(--text-copy);"><code>{`# Add to your .mcp.json or client config
{
  "mcpServers": {
    "telepathine": {
      "command": "npx",
      "args": ["-y", "@ai-memory/mcp-server"],
      "env": {
        "TELEPATHINE_API_KEY": "your_api_key_here"
      }
    }
  }
}`}</code></pre>
        <p class="mt-3 text-sm" style="color: var(--text-muted);">That's it. Your agent now has 16 memory tools available. No code changes to your agent. No database to configure.</p>
      </div>

      <div>
        <h2>The 16 MCP tools</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {toolList.map(tool => (
            <div class="surface-card p-3">
              <code class="text-xs font-mono" style="color: var(--accent);">{tool.name}</code>
              <p class="mt-1 text-xs" style="color: var(--text-muted);">{tool.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2>Why MCP-native matters</h2>
        <p class="mt-3" style="color: var(--text-muted);">Most memory solutions bolt MCP on as an afterthought — a thin wrapper around a REST API. Telepathine.ai was designed MCP-native from the start. Every operation is a first-class tool with proper input schemas, error handling, and type safety.</p>
        <p class="mt-3" style="color: var(--text-muted);">This means your agent doesn't need to construct HTTP requests or handle API errors. It calls a tool. The MCP server handles auth, rate limiting, retries, and response formatting.</p>
      </div>

      <div>
        <h2>MCP memory vs. built-in memory</h2>
        <div class="mt-4 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr style="border-bottom: 1px solid var(--line);">
                <th class="pb-3 pr-4 text-left text-xs" style="color: var(--text-muted);">Dimension</th>
                <th class="pb-3 px-3 text-left text-xs" style="color: var(--text-muted);">Built-in Memory</th>
                <th class="pb-3 pl-3 text-left text-xs" style="color: var(--text-muted);">MCP Memory Server</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
                <td class="py-3 pr-4" style="color: var(--text-copy);">Portability</td>
                <td class="py-3 px-3" style="color: var(--text-muted);">Locked to one agent</td>
                <td class="py-3 pl-3" style="color: var(--text-muted);">Works with every MCP client</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
                <td class="py-3 pr-4" style="color: var(--text-copy);">Project scope</td>
                <td class="py-3 px-3" style="color: var(--text-muted);">User-level or none</td>
                <td class="py-3 pl-3" style="color: var(--text-muted);">Project-scoped by default</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
                <td class="py-3 pr-4" style="color: var(--text-copy);">Search</td>
                <td class="py-3 px-3" style="color: var(--text-muted);">Keyword only</td>
                <td class="py-3 pl-3" style="color: var(--text-muted);">Hybrid (FTS + semantic)</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
                <td class="py-3 pr-4" style="color: var(--text-copy);">Intelligence</td>
                <td class="py-3 px-3" style="color: var(--text-muted);">Raw storage</td>
                <td class="py-3 pl-3" style="color: var(--text-muted);">Morpheus pipeline</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--line); opacity: 0.8;">
                <td class="py-3 pr-4" style="color: var(--text-copy);">Agent comms</td>
                <td class="py-3 px-3" style="color: var(--text-muted);">None</td>
                <td class="py-3 pl-3" style="color: var(--text-muted);">Signal Bus (16th tool)</td>
              </tr>
              <tr style="opacity: 0.8;">
                <td class="py-3 pr-4" style="color: var(--text-copy);">Self-host</td>
                <td class="py-3 px-3" style="color: var(--text-muted);">No</td>
                <td class="py-3 pl-3" style="color: var(--text-muted);">Apache 2.0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="surface-panel p-6 text-center">
        <h3>Add memory to your agent</h3>
        <p class="mt-2 text-sm" style="color: var(--text-muted);">One config entry. 16 tools. Any MCP client.</p>
        <div class="mt-4 flex items-center justify-center gap-4">
          <a href="/api/mcp" class="btn-accent">MCP Docs →</a>
          <a href="/docs/quickstart" class="btn-ghost">Quick Start</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
