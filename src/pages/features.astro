---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    label: 'Principal',
    title: 'Signal Bus',
    description: 'Comunicación entre agentes mediante transmisión estructurada de mensajes. Registra agentes en canales, transmite pensamientos, retransmite a través de una malla de canales. El Memory Bridge persiste automáticamente los mensajes como observaciones. Ningún otro producto de memoria incluye un bus de comunicación entre agentes en tiempo real.',
    code: `import { telepathine } from '@telepathine/sdk';\n\nconst bus = telepathine.bus('swarm-alpha');\nbus.on('thought', (msg) => {\n  console.log(msg.agent, msg.payload);\n});\nawait bus.broadcast({ type: 'finding', payload: data });`,
    codeFile: 'bus.ts',
    visual: 'bus',
  },
  {
    label: 'Fundamento',
    title: 'Observaciones Persistentes',
    description: 'Registra decisiones, cambios, aprendizajes e interacciones con herramientas como observaciones estructuradas. Cada observación recibe un tipo, título, narrativa, hechos extraídos y conceptos clave — enriquecidos automáticamente por el pipeline Morpheus. Cada sesión enriquece un grafo de memoria compartido.',
    code: `await telepathine.observe({\n  type: 'decision',\n  title: 'Migrated auth to JWT',\n  narrative: 'Replaced session cookies...',\n  facts: ['Uses RS256', '15min access tokens'],\n});`,
    codeFile: 'observe.ts',
    visual: 'observe',
  },
  {
    label: 'Inteligencia',
    title: 'Búsqueda Híbrida',
    description: 'Combina búsqueda de texto completo (FTS) y similitud vectorial semántica en una sola consulta. El motor híbrido fusiona resultados de ambos índices, ponderados 60/40 para relevancia óptima. Soporta modos fts-only, vector-only o híbrido. Scoped a tu proyecto.',
    code: `const results = await telepathine.search({\n  query: 'authentication migration',\n  mode: 'hybrid',\n  project: 'my-app',\n  limit: 10,\n});`,
    codeFile: 'search.ts',
    visual: 'search',
  },
  {
    label: 'Entrega',
    title: 'Inyección de Contexto',
    description: 'Revelado progresivo: contexto comprimido y formateado inyectado en el prompt de tu agente al inicio de sesión. Encabezado, línea de tiempo, resumen, pie. Tu agente ve lo que necesita, no un volcado de datos. ~7,000 tokens de contexto relevante — no 25,000+ de historial bruto.',
    code: `const ctx = await telepathine.inject({\n  project: 'my-app',\n  scope: 'global',\n  limit: 5,\n});\n// Injected into agent prompt automatically`,
    codeFile: 'inject.ts',
    visual: 'inject',
  },
  {
    label: 'Procesamiento',
    title: 'Pipeline Morpheus',
    description: 'Procesamiento de observaciones con LLM: normalizar, deduplicar, reemplazar entradas obsoletas, aplicar decaimiento temporal, consolidar y generar retrospectivas. La salida bruta de herramientas se convierte en conocimiento estructurado y buscable. Los resúmenes de sesión persisten para futuras inyecciones de contexto.',
    code: `// Automatic on session complete\n// Morpheus processes:\n// 1. Normalize dates, formats\n// 2. Deduplicate observations\n// 3. Supersede stale entries\n// 4. Apply temporal decay\n// 5. Consolidate related items\n// 6. Generate session summary`,
    codeFile: 'morpheus.ts',
    visual: 'morpheus',
  },
  {
    label: 'Ciclo de vida',
    title: 'Continuidad de Sesión',
    description: 'Inicia una sesión, registra observaciones, resume, completa. Las sesiones rastrean el trabajo de tu agente a lo largo de una interacción. Los resúmenes persisten para futuras inyecciones de contexto. La recuperación por compactación preserva la identidad del agente a través de los límites de la ventana de contexto.',
    code: `const session = await telepathine.session.start({\n  project: 'my-app',\n  agent: 'claude-code',\n});\n// ... agent works ...\nawait session.complete(); // Auto-summarize`,
    codeFile: 'session.ts',
    visual: 'session',
  },
  {
    label: 'Aislamiento',
    title: 'Aislamiento Multi-Tenant',
    description: 'Los datos de cada tenant están completamente aislados con seguridad a nivel de fila (políticas FORCE). Las API keys están scoped a read/write/admin. Los controles de visibilidad de proyecto (privado, tenant, compartido) ofrecen acceso granular. Sin fallback por defecto. Las pruebas de regresión evitan su reintroducción.',
    code: `-- RLS policy enforced on every table\nCREATE POLICY tenant_isolation ON observations\n  USING (tenant_id = current_setting('app.tenant'))\n  WITH CHECK (tenant_id = current_setting('app.tenant'));`,
    codeFile: 'rls.sql',
    visual: 'isolation',
  },
  {
    label: 'Flexibilidad',
    title: 'Trae Tu Propia Key',
    description: 'Configura tus propios proveedores de LLM y embeddings por tenant. Usa OpenAI, Anthropic o cualquier endpoint compatible. Tus keys de IA están hasheadas en reposo y nunca se comparten. BYOK es gratis en cada plan — reduce costos de infra y genera confianza.',
    code: `# .brain/memory.yaml\nllm:\n  provider: anthropic\n  model: claude-sonnet-4-20250514\n  apiKey: \$\{TELEPATHINE_LLM_KEY\}\nembedding:\n  provider: openai\n  model: text-embedding-3-small`,
    codeFile: 'config.yaml',
    visual: 'byok',
  },
  {
    label: 'Integración',
    title: '17 Conectores',
    description: 'Adaptadores pre-construidos para cada agente de código importante: Claude Code, Cursor, Gemini, Windsurf, Copilot, Pi, Hermes y más. El servidor MCP da acceso a cualquier cliente compatible con MCP. Instala en 30 segundos.',
    code: `$ npx @telepathine/connector install cursor\n# or for Claude Code:\n$ npx @telepathine/connector install claude\n# or use the MCP server:\n$ npx @telepathine/mcp-server`,
    codeFile: 'terminal',
    visual: 'connectors',
  },
];
---

<BaseLayout
  title="Funciones — Telepathine.ai"
  description="La capa de inteligencia completa para agentes IA: Signal Bus, observaciones persistentes, búsqueda híbrida, inyección de contexto progresiva, pipeline Morpheus, ciclo de vida de sesión y aislamiento multi-tenant."
>
  <!-- ====== HEADER ====== -->
  <section class="content-layer px-4 pb-4 pt-24 sm:px-6 sm:pt-32 lg:px-8">
    <div class="mx-auto max-w-[1280px] text-left">
      <span class="layer-label">Funciones</span>
      <h1 class="mt-4">La capa de inteligencia completa para agentes IA</h1>
      <p class="mt-4 max-w-2xl" style="color: var(--text-muted); line-height: 1.7;">
        Desde coordinación de agentes en tiempo real hasta persistencia de memoria estructurada — todo lo que tus agentes necesitan para recordar, comunicarse y construir conocimiento institucional.
      </p>
    </div>
  </section>

  <!-- ====== HOW IT WORKS (4-step pipeline) ====== -->
  <section class="content-layer px-4 py-16 sm:px-6 lg:px-8" style="border-bottom: 1px solid var(--line);">
    <div class="mx-auto max-w-[1280px]">
      <span class="layer-label">Pipeline</span>
      <h2 class="mt-4">Cómo funciona</h2>

      <div class="mt-10 grid gap-6 md:grid-cols-4">
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">1</span>
            <h3 style="margin: 0;">Observar</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Los agentes capturan decisiones, cambios, aprendizajes e interacciones con herramientas como observaciones estructuradas.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">2</span>
            <h3 style="margin: 0;">Enriquecer</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Pipeline Morpheus: normalizar, deduplicar, reemplazar obsoletos, consolidar, generar resúmenes.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">3</span>
            <h3 style="margin: 0;">Inyectar</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Revelado progresivo: ~7K tokens de contexto relevante al inicio de sesión, no un volcado de datos.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-4">
            <span class="step-circle">4</span>
            <h3 style="margin: 0;">Conectar</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted); line-height: 1.6;">
            Los agentes transmiten en canales. Coordina enjambres, comparte hallazgos, mantente sincronizado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURE SECTIONS (zig-zag) ====== -->
  {features.map((feat, i) => (
    <section class={`content-layer px-4 py-20 sm:px-6 lg:px-8${i < features.length - 1 ? ' [border-bottom:1px_solid_var(--line-subtle)]' : ''}`}>
      <div class="mx-auto grid max-w-[1280px] items-center gap-12 md:grid-cols-2">
        {i % 2 === 0 ? (
          <!-- Text left, code right -->
          <>
            <div class="flex flex-col gap-6">
              <span class="layer-label">{feat.label}</span>
              <h2>{feat.title}</h2>
              <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">{feat.description}</p>
            </div>
            <div class="code-terminal shadow-lg">
              <div class="code-terminal-bar">
                <span class="code-terminal-dot code-terminal-dot-red"></span>
                <span class="code-terminal-dot code-terminal-dot-yellow"></span>
                <span class="code-terminal-dot code-terminal-dot-green"></span>
                <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">{feat.codeFile}</span>
              </div>
              <div class="code-terminal-body">
                <pre class="whitespace-pre-wrap">{feat.code}</pre>
              </div>
            </div>
          </>
        ) : (
          <!-- Code left, text right -->
          <>
            <div class="order-2 flex flex-col gap-6 md:order-1">
              <span class="layer-label">{feat.label}</span>
              <h2>{feat.title}</h2>
              <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.7;">{feat.description}</p>
            </div>
            <div class="order-1 code-terminal shadow-lg md:order-2">
              <div class="code-terminal-bar">
                <span class="code-terminal-dot code-terminal-dot-red"></span>
                <span class="code-terminal-dot code-terminal-dot-yellow"></span>
                <span class="code-terminal-dot code-terminal-dot-green"></span>
                <span class="ml-4 font-mono text-[10px]" style="color: var(--text-muted);">{feat.codeFile}</span>
              </div>
              <div class="code-terminal-body">
                <pre class="whitespace-pre-wrap">{feat.code}</pre>
              </div>
            </div>
          </>
        )}
      </div>
    </section>
  ))}

  <!-- ====== CTA ====== -->
  <section class="content-layer px-4 py-20 sm:px-6 lg:px-8" style="border-top: 1px solid var(--line); background: var(--bg-deep);">
    <div class="mx-auto max-w-[1280px] text-left">
      <h2>Ningún agente parte desde cero</h2>
      <p class="mt-4 max-w-xl" style="color: var(--text-muted);">Empieza gratis con 10K observaciones. Sin tarjeta de crédito.</p>
      <div class="mt-8 flex items-center gap-4">
        <a href="/pricing" class="btn-accent">Empezar gratis</a>
        <a href="/docs/quickstart" class="btn-ghost">Guía de inicio rápido</a>
      </div>
    </div>
  </section>
</BaseLayout>
