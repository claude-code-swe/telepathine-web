---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const SITE_URL = 'https://telepathine.ai';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const description = doc.data.description || `Telepathine.ai documentation: ${doc.data.title}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: doc.data.title,
  description,
  url: `${SITE_URL}/docs/${doc.slug}`,
  author: {
    '@type': 'Organization',
    name: 'ELiA',
  },
  publisher: {
    '@type': 'Organization',
    name: 'ELiA',
  },
};
---

<DocsLayout title={doc.data.title} description={description} jsonLd={jsonLd}>
  <h1 class="text-3xl font-bold">{doc.data.title}</h1>
  <div class="prose prose-invert max-w-none mt-8
    [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
    [&_h2]:text-xl [&_h2]:font-serif
    [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
    [&_h3]:text-lg [&_h3]:font-serif
    [&_p]:leading-relaxed
    [&_code]:rounded [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm
    [&_pre]:rounded-lg [&_pre]:p-4 [&_pre]:text-sm
    [&_pre]:border
    [&_a]:underline
    [&_ul]:list-disc [&_ul]:pl-5
    [&_ol]:list-decimal [&_ol]:pl-5
    [&_li]:mb-1
    [&_table]:w-full
    [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_th]:text-xs
    [&_td]:px-3 [&_td]:py-2 [&_td]:text-sm
    "
    style={`
      --tw-prose-body: var(--text-copy);
      --tw-prose-headings: var(--text);
      --tw-prose-links: var(--accent);
      --tw-prose-code: var(--accent);
      --tw-prose-pre-bg: var(--bg-code);
      --tw-prose-pre-border: var(--line);
      --tw-prose-pre-code: var(--text-copy);
      --tw-prose-th-borders: var(--line);
      --tw-prose-td-borders: var(--line);
      --tw-prose-bold: var(--text-strong);
      color: var(--text-copy);
    `}
  >
    <Content />
  </div>
</DocsLayout>
