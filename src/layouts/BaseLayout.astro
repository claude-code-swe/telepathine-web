---
import '../styles/global.css';
import { BRAND } from '../data/brand';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: object;
  canonicalUrl?: string;
}

const SITE_URL = BRAND.SITE_URL;
const SITE_NAME = BRAND.SITE_NAME;
const DEFAULT_OG_IMAGE = '/og-image.svg';

const { title, description = BRAND.DEFAULT_DESCRIPTION, ogImage = DEFAULT_OG_IMAGE, jsonLd, canonicalUrl } = Astro.props;

const fullTitle = title.includes(' — ') ? title : `${title} — ${SITE_NAME}`;
const resolvedCanonical = canonicalUrl || `${SITE_URL}${Astro.url.pathname.replace(/\/index\.html$/, '').replace(/\.html$/, '')}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;

const navLinks = [
  { label: 'Features', href: '/features' },
  { label: 'Connectors', href: '/connectors' },
  { label: 'API', href: '/api' },
  { label: 'Docs', href: '/docs' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Security', href: '/security' },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="min-h-screen antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b backdrop-blur-md" style={`background: var(--bg-deep); border-color: var(--line);`}>
      <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-2 text-lg font-bold" style="color: var(--text);">
          <svg width="20" height="20" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M32 4L58 18V46L32 60L6 46V18L32 4Z" stroke="#0AE5A0" stroke-width="3" fill="none"/>
            <path d="M32 22L40 26.5V35.5L32 40L24 35.5V26.5L32 22Z" fill="#0AE5A0"/>
          </svg>
          <span>Telepathine.ai</span>
        </a>
        <div class="hidden items-center gap-6 md:flex">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{link.label}</a>
          ))}
        </div>
        <div class="flex items-center gap-3">
          <a href="/pricing" class="btn-accent">Start Free</a>
          <button id="mobile-menu-btn" class="md:hidden" style="color: var(--text-muted);" aria-label="Toggle menu">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="mobile-menu md:hidden">
        <div class="flex flex-col gap-2 px-4 py-3">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{link.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <main class="content-layer pt-14">
      <slot />
    </main>

    <footer class="content-layer section-divider" style="background: var(--bg-deep);">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
          <div>
            <div class="flex items-center gap-2 text-lg font-bold" style="color: var(--text);">
              <svg width="20" height="20" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M32 4L58 18V46L32 60L6 46V18L32 4Z" stroke="#0AE5A0" stroke-width="3" fill="none"/>
                <path d="M32 22L40 26.5V35.5L32 40L24 35.5V26.5L32 22Z" fill="#0AE5A0"/>
              </svg>
              <span>Telepathine.ai</span>
            </div>
            <p class="mt-3 text-sm" style="color: var(--text-muted);">Your memory should outlive your agent.<br/>Works with every coding agent.</p>
          </div>
          <div>
            <h4 class="text-sm font-semibold" style="color: var(--text-strong);">Product</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="/features" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Features</a></li>
              <li><a href="/connectors" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Connectors</a></li>
              <li><a href="/pricing" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Pricing</a></li>
              <li><a href="/changelog" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Changelog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold" style="color: var(--text-strong);">Developers</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="/docs/quickstart" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Quick Start</a></li>
              <li><a href="/api" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">API Reference</a></li>
              <li><a href="/api/mcp" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">MCP Server</a></li>
              <li><a href="/api/sdks" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">SDKs</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold" style="color: var(--text-strong);">Company</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="/architecture" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Architecture</a></li>
              <li><a href="/security" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Security</a></li>
              <li><a href="/changelog" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Changelog</a></li>
              <li><a href="https://github.com/ArtemisAI/agent-memory" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">GitHub</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-semibold" style="color: var(--text-strong);">Guides</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="/what-is-ai-agent-memory" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">What Is AI Agent Memory</a></li>
              <li><a href="/mcp-memory-server" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">MCP Memory Server</a></li>
              <li><a href="/model-agnostic-memory" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Model-Agnostic Memory</a></li>
              <li><a href="/agent-communication-bus" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Agent Communication Bus</a></li>
              <li><a href="/claude-memory-alternative" class="text-sm transition" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Claude Memory Alternative</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 pt-6 text-center text-xs" style="border-top: 1px solid var(--line); color: var(--text-muted); opacity: 0.7;">
          © 2026 ArtemisAI. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('is-open'));
    </script>
  </body>
</html>
